<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="LSMA.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" HorizontalContentAlignment="Stretch">
        <StackPanel Padding="30,22,30,30" Spacing="18" HorizontalAlignment="Stretch">
            <Border Style="{StaticResource CardStyle}" Visibility="{Binding MissingDirectoryVisibility}">
                <StackPanel Spacing="16">
                    <FontIcon Glyph="&#xE7BA;" FontSize="28" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Left" />
                    <TextBlock Text="未找到星露谷物语安装目录" Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="请选择游戏安装文件夹。需要包含 Stardew Valley.exe 或 StardewModdingAPI.exe。" Style="{StaticResource BodyTextStyle}" MaxWidth="560" />
                    <Button Content="选择游戏目录" Command="{Binding ChooseDirectoryCommand}" Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Left" />
                </StackPanel>
            </Border>

            <StackPanel Visibility="{Binding ConnectedVisibility}" Spacing="18">
                <InfoBar IsOpen="True" Severity="Warning" IsClosable="False" Title="游戏正在运行"
                         Message="为避免损坏文件，LSMA 暂停模组和存档修改操作。"
                         Visibility="{Binding RunningVisibility}" />
                <InfoBar IsOpen="True" Severity="Error" IsClosable="False" Title="可恢复到稳定状态"
                         Message="最近启动发生崩溃，可恢复到上次无错误退出时的模组组合。"
                         Visibility="{Binding StableRecoveryVisibility}">
                    <InfoBar.ActionButton>
                        <Button Content="恢复" Command="{Binding RestoreStableStateCommand}" Style="{StaticResource DangerButtonStyle}" />
                    </InfoBar.ActionButton>
                </InfoBar>

                <Border Style="{StaticResource CardStyle}">
                    <Grid ColumnSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="48" Height="48" CornerRadius="24" Background="{ThemeResource AccentSoftBrush}">
                            <Grid>
                                <FontIcon Glyph="&#xE930;" Foreground="{StaticResource SuccessBrush}" FontSize="20" Visibility="{Binding ReadyVisibility}" />
                                <FontIcon Glyph="&#xE7BA;" Foreground="{StaticResource WarningBrush}" FontSize="20" Visibility="{Binding AttentionVisibility}" />
                                <FontIcon Glyph="&#xEA39;" Foreground="{StaticResource DangerBrush}" FontSize="20" Visibility="{Binding BlockedVisibility}" />
                            </Grid>
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="5">
                            <TextBlock Text="{Binding StatusTitle}" Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock Text="{Binding StatusDetail}" Style="{StaticResource BodyTextStyle}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <Grid ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="5">
                            <TextBlock Text="启动前助手" Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock Text="{Binding LaunchProfileText}" Style="{StaticResource BodyTextStyle}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="9" VerticalAlignment="Center">
                            <Button Content="一键检查" Command="{Binding CheckCommand}" Style="{StaticResource SubtleButtonStyle}" />
                            <Button Content="一键修复" Command="{Binding RepairCommand}" Style="{StaticResource SubtleButtonStyle}" />
                            <Button Content="启动方式" Style="{StaticResource SubtleButtonStyle}">
                                <Button.Flyout>
                                    <MenuFlyout>
                                        <MenuFlyoutSubItem Text="启动程序">
                                            <MenuFlyoutItem Text="SMAPI" Click="UseSmapi_Click" />
                                            <MenuFlyoutItem Text="原版" Click="UseVanilla_Click" />
                                        </MenuFlyoutSubItem>
                                        <MenuFlyoutSubItem Text="检查模式">
                                            <MenuFlyoutItem Text="快速启动" Click="UseQuickMode_Click" />
                                            <MenuFlyoutItem Text="安全启动" Click="UseSafeMode_Click" />
                                            <MenuFlyoutItem Text="诊断启动" Click="UseDiagnosticMode_Click" />
                                        </MenuFlyoutSubItem>
                                    </MenuFlyout>
                                </Button.Flyout>
                            </Button>
                            <Button Content="启动游戏" Command="{Binding LaunchGameCommand}" Style="{StaticResource AccentButtonStyle}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <ProgressRing IsActive="{Binding IsBusy}" Width="24" Height="24" HorizontalAlignment="Left" />
                <TextBlock Text="{Binding ProgressText}" Style="{StaticResource BodyTextStyle}" />
                <TextBlock Text="{Binding FeedbackMessage}" Foreground="{StaticResource SuccessBrush}" />

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel Spacing="7"><TextBlock Text="模组状态" Style="{StaticResource BodyTextStyle}" /><TextBlock Text="{Binding ModSummaryText}" Style="{StaticResource SectionTitleStyle}" /></StackPanel>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                        <StackPanel Spacing="7"><TextBlock Text="存档状态" Style="{StaticResource BodyTextStyle}" /><TextBlock Text="{Binding SaveSummaryText}" Style="{StaticResource SectionTitleStyle}" /></StackPanel>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                        <StackPanel Spacing="7"><TextBlock Text="今日建议" Style="{StaticResource BodyTextStyle}" /><TextBlock Text="{Binding SuggestionSummaryText}" Style="{StaticResource SectionTitleStyle}" TextWrapping="Wrap" /></StackPanel>
                    </Border>
                    <Border Grid.Column="3" Style="{StaticResource CardStyle}">
                        <StackPanel Spacing="7"><TextBlock Text="最近错误" Style="{StaticResource BodyTextStyle}" /><TextBlock Text="{Binding LogSummaryText}" Style="{StaticResource SectionTitleStyle}" TextWrapping="Wrap" /></StackPanel>
                    </Border>
                </Grid>

                <Expander Header="启动详情与诊断">
                    <Border Style="{StaticResource CardStyle}" Margin="0,8,0,0">
                        <StackPanel Spacing="12">
                            <TextBlock Text="{Binding LogSummaryText}" Style="{StaticResource BodyTextStyle}" />
                            <TextBlock Text="{Binding MostLikelyCause}" Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock Text="{Binding RecommendedAction}" Style="{StaticResource BodyTextStyle}" />
                            <ItemsControl ItemsSource="{Binding LogIssues}" Visibility="{Binding LogDetailVisibility}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="0,1,0,0" Padding="0,8">
                                            <StackPanel Spacing="3">
                                                <TextBlock Text="{Binding Category}" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Summary}" Style="{StaticResource BodyTextStyle}" />
                                                <TextBlock Text="{Binding Recommendation}" Style="{StaticResource MutedTextStyle}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button Content="复制诊断报告" Command="{Binding CopyReportCommand}" Style="{StaticResource SubtleButtonStyle}" />
                                <Button Content="导出报告" Command="{Binding ExportReportCommand}" Style="{StaticResource SubtleButtonStyle}" />
                                <Button Content="打开日志目录" Command="{Binding OpenLogsCommand}" Style="{StaticResource SubtleButtonStyle}" />
                                <Button Content="仍然启动" Command="{Binding LaunchGameCommand}" Style="{StaticResource DangerButtonStyle}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Expander>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
