<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="LSMA.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{ThemeResource AppBackgroundBrush}">
        <Image
            Source="{Binding HomeBackgroundImageUri}"
            Stretch="UniformToFill"
            Opacity="1"
            Visibility="{Binding HomeBackgroundVisibility}" />
        <Border Background="#A80E1116" />
        <Border
            Background="#301D2517"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch" />

        <ScrollViewer HorizontalScrollBarVisibility="Disabled" HorizontalContentAlignment="Stretch">
            <StackPanel Padding="30,22,30,116" Spacing="14" HorizontalAlignment="Stretch">
                <Border Style="{StaticResource CardStyle}" Visibility="{Binding MissingDirectoryVisibility}" MaxWidth="620" HorizontalAlignment="Left">
                    <StackPanel Spacing="14">
                        <FontIcon Glyph="&#xE7BA;" FontSize="28" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Left" />
                        <TextBlock Text="未找到星露谷物语安装目录" Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="请选择包含 Stardew Valley.exe 或 StardewModdingAPI.exe 的文件夹。" Style="{StaticResource BodyTextStyle}" />
                        <Button Content="选择游戏目录" Command="{Binding ChooseDirectoryCommand}" Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Left" />
                    </StackPanel>
                </Border>

                <StackPanel Visibility="{Binding ConnectedVisibility}" Spacing="12" MaxWidth="620" HorizontalAlignment="Left">
                    <InfoBar IsOpen="True" Severity="Warning" IsClosable="False" Title="游戏正在运行"
                             Message="文件修改操作已暂停。"
                             Visibility="{Binding RunningVisibility}" />
                    <InfoBar IsOpen="True" Severity="Error" IsClosable="False" Title="可恢复到稳定状态"
                             Message="最近启动发生崩溃，可恢复到上次无错误退出时的模组组合。"
                             Visibility="{Binding StableRecoveryVisibility}">
                        <InfoBar.ActionButton>
                            <Button Content="恢复" Command="{Binding RestoreStableStateCommand}" Style="{StaticResource DangerButtonStyle}" />
                        </InfoBar.ActionButton>
                    </InfoBar>

                    <Border
                        Background="#D91A1B20"
                        BorderBrush="{ThemeResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="18"
                        Visibility="{Binding ModAttentionVisibility}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="模组状态" Foreground="#F7F8FA" FontSize="16" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding ModSummaryText}" Foreground="#D9F7F8FA" FontSize="14" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border
                        Background="#D91A1B20"
                        BorderBrush="{ThemeResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="18"
                        Visibility="{Binding LogAttentionVisibility}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="最近错误" Foreground="#F7F8FA" FontSize="16" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding MostLikelyCause}" Foreground="#D9F7F8FA" FontSize="14" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding RecommendedAction}" Foreground="#B8F7F8FA" FontSize="13" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" Spacing="10" Visibility="{Binding BusyVisibility}">
                        <ProgressRing IsActive="{Binding IsBusy}" Width="24" Height="24" />
                        <TextBlock Text="{Binding ProgressText}" Foreground="#D9F7F8FA" FontSize="14" VerticalAlignment="Center" TextWrapping="Wrap" />
                    </StackPanel>
                    <TextBlock Text="{Binding FeedbackMessage}" Foreground="{StaticResource SuccessBrush}" FontSize="14" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Border
            x:Name="LaunchFloatingArea"
            CornerRadius="28"
            Background="#E61A1B20"
            BorderBrush="{ThemeResource CardBorderBrush}"
            BorderThickness="1"
            Padding="18,16"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Margin="0,0,24,24"
            PointerEntered="LaunchFloating_PointerEntered"
            PointerExited="LaunchFloating_PointerExited">
            <StackPanel>
                <StackPanel x:Name="LaunchOptionsPopup" Visibility="Collapsed" Spacing="10" Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                        <Button x:Name="SmapiBtn" Content="SMAPI" Click="LaunchSmapi_Click"
                                Style="{StaticResource AccentButtonStyle}" FontSize="15" Padding="18,8" />
                        <Button x:Name="VanillaBtn" Content="原版" Click="LaunchVanilla_Click"
                                Style="{StaticResource SubtleButtonStyle}" FontSize="15" Padding="18,8" />
                    </StackPanel>
                    <CheckBox x:Name="SteamCheckbox" Content="通过 Steam 启动" HorizontalAlignment="Right"
                              Foreground="#F7F8FA"
                              Checked="SteamCheckbox_Changed" Unchecked="SteamCheckbox_Changed" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="14" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding StatusTitle}" Foreground="#F7F8FA" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Button Content="启动游戏" Style="{StaticResource AccentButtonStyle}" FontSize="22"
                            Padding="32,16" MinWidth="180" Click="LaunchGameBtn_Click" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
