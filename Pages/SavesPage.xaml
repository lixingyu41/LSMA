<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="LSMA.Pages.SavesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Page.Resources>
        <DataTemplate x:Key="MetricTileTemplate">
            <Grid>
                <Border Style="{StaticResource CardStyle}" Padding="13" MinHeight="86" ToolTipService.ToolTip="{Binding Detail}">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon
                            Glyph="{Binding Glyph}"
                            FontSize="16"
                            Foreground="{StaticResource AccentBrush}"
                            Visibility="{Binding GlyphVisibility}"
                            VerticalAlignment="Top" />
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="{Binding Name}" FontSize="13" Foreground="{ThemeResource MutedTextBrush}" />
                            <TextBlock Text="{Binding Value}" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="HeroMetricTemplate">
            <Grid>
                <Border
                    Background="Transparent"
                    BorderBrush="{ThemeResource CardBorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="0,0,0,8"
                    ToolTipService.ToolTip="{Binding Detail}">
                    <StackPanel>
                        <TextBlock Text="{Binding Value}" FontSize="20" FontWeight="SemiBold" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding Name}" Style="{StaticResource MutedTextStyle}" />
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="ProgressRowTemplate">
            <Grid Margin="0,6" ColumnSpacing="12" RowSpacing="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                <TextBlock Grid.Column="1" Text="{Binding Value}" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" />
                <ProgressBar Grid.Row="1" Grid.ColumnSpan="2" Value="{Binding Percent}" Maximum="100" Height="7" Foreground="{StaticResource AccentBrush}" />
                <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="{Binding Detail}" Style="{StaticResource MutedTextStyle}" Visibility="{Binding DetailVisibility}" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="CompactProgressTileTemplate">
            <Grid>
                <Border
                    Background="{ThemeResource CardBackgroundBrush}"
                    BorderBrush="{ThemeResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10"
                    MinHeight="72"
                    ToolTipService.ToolTip="{Binding Detail}">
                    <Grid RowSpacing="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="1" Text="{Binding Value}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" />
                        </Grid>
                        <ProgressBar Grid.Row="1" Value="{Binding Percent}" Maximum="100" Height="6" Foreground="{StaticResource AccentBrush}" />
                    </Grid>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="MetricRowTemplate">
            <Grid Margin="0,4" ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="1" Text="{Binding Value}" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="FishRowTemplate">
            <Grid Margin="0,4" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Image Source="{Binding IconUri}" Width="22" Height="22" Stretch="Uniform" Visibility="{Binding IconVisibility}" />
                <TextBlock Grid.Column="1" Text="{Binding Name}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                <TextBlock Grid.Column="2" Text="{Binding Value}" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="CatchTileTemplate">
            <Grid>
                <Border
                    Background="{ThemeResource CardBackgroundBrush}"
                    BorderBrush="{ThemeResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="8"
                    MinHeight="58">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid Width="28" Height="28" VerticalAlignment="Center">
                            <Image Source="{Binding IconUri}" Width="26" Height="26" Stretch="Uniform" Visibility="{Binding IconVisibility}" />
                            <FontIcon Glyph="{Binding Glyph}" FontSize="18" Foreground="{StaticResource AccentBrush}" Visibility="{Binding FallbackGlyphVisibility}" />
                        </Grid>
                        <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding Value}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                    </Grid>
                </Border>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid Padding="25,12,20,2" RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Padding="10,6" Visibility="{Binding AvailableVisibility}" MaxWidth="1180">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <ComboBox
                        ItemsSource="{Binding Saves}"
                        SelectedItem="{Binding SelectedSave, Mode=TwoWay}"
                        Width="220"
                        Height="32">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Image Source="{Binding SeasonIconUri}" Width="20" Height="20" Stretch="Uniform" />
                                    <TextBlock Text="{Binding ListDisplay}" VerticalAlignment="Center" FontSize="14" />
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock Text="{Binding SavesCountDisplay}" VerticalAlignment="Center" Style="{StaticResource MutedTextStyle}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="4,0">
                    <ProgressRing IsActive="{Binding IsBusy}" Width="19" Height="19" />
                    <TextBlock Text="{Binding ProgressText}" Style="{StaticResource BodyTextStyle}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding FeedbackMessage}" Foreground="{StaticResource SuccessBrush}" VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock
                        Text="{Binding BackupStatus}"
                        VerticalAlignment="Center"
                        Style="{StaticResource MutedTextStyle}"
                        ToolTipService.ToolTip="{Binding BackupToolTip}" />
                    <ComboBox
                        ItemsSource="{Binding BackupEntries}"
                        SelectedItem="{Binding SelectedBackup, Mode=TwoWay}"
                        DisplayMemberPath="DisplayName"
                        PlaceholderText="选择备份"
                        Width="130"
                        Height="32" />
                    <Button Content="恢复" Command="{Binding RestoreCommand}" Style="{StaticResource DangerButtonStyle}" />
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Content="备份当前" Command="{Binding BackupCommand}" Style="{StaticResource AccentButtonStyle}" />
                    <Button Content="备份全部" Command="{Binding BackupAllCommand}" Style="{StaticResource AccentButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Visibility="{Binding UnavailableVisibility}">
            <StackPanel Spacing="10">
                <TextBlock Text="存档功能暂不可用" Style="{StaticResource SectionTitleStyle}" />
                <TextBlock Text="连接游戏目录后即可读取本机存档并创建备份。" Style="{StaticResource BodyTextStyle}" />
            </StackPanel>
        </Border>

        <InfoBar
            Grid.Row="1"
            IsOpen="True"
            IsClosable="False"
            Severity="Warning"
            Title="游戏正在运行"
            Message="当前可以查看存档，但恢复操作已暂停。"
            Visibility="{Binding RunningVisibility}" />

        <ScrollViewer
            x:Name="DetailScrollViewer"
            Grid.Row="2"
            Visibility="{Binding AvailableVisibility}"
            Padding="0"
            VerticalScrollBarVisibility="Hidden"
            HorizontalScrollBarVisibility="Hidden"
            HorizontalScrollMode="Disabled"
            HorizontalContentAlignment="Stretch"
            Canvas.ZIndex="1000">
            <StackPanel x:Name="DetailContent" Spacing="16" Visibility="{Binding DetailVisibility}" Margin="0,30,0,0" HorizontalAlignment="Left">
                <Border x:Name="HeroCard" Style="{StaticResource CardStyle}" Padding="0" MinHeight="188" HorizontalAlignment="Stretch" MaxWidth="1180">
                    <Grid Padding="18" ColumnSpacing="18" RowSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Width="92" Height="118" CornerRadius="10" BorderBrush="{StaticResource AccentBrush}" BorderThickness="2" Background="{ThemeResource AccentSoftBrush}">
                            <Grid>
                                <Image Source="{Binding SelectedSave.BackgroundImageUri}" Stretch="UniformToFill" Opacity="0.78" Visibility="{Binding SaveBackgroundVisibility}" />
                                <Border Background="{ThemeResource CardBackgroundBrush}" Opacity="0.18" />
                                <Image Source="{Binding SelectedSave.PortraitImageUri}" Stretch="Uniform" Margin="12,8,12,6" VerticalAlignment="Bottom" />
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="1" Spacing="7" VerticalAlignment="Center">
                            <TextBlock Text="{Binding SelectedSave.FarmerName}" FontSize="26" FontWeight="SemiBold" Foreground="{ThemeResource PrimaryTextBrush}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding SelectedSave.FarmName}" FontSize="16" Foreground="{StaticResource AccentBrush}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding SelectedSave.DateDisplay}" Style="{StaticResource BodyTextStyle}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding SelectedSave.FarmType}" Style="{StaticResource MutedTextStyle}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>

                        <TextBlock Grid.Column="2" Text="{Binding SelectedSave.UniqueGameIdDisplay}" Style="{StaticResource MutedTextStyle}" HorizontalAlignment="Right" MaxWidth="170" TextTrimming="CharacterEllipsis" />

                        <ItemsRepeater Grid.Row="1" Grid.ColumnSpan="3" ItemsSource="{Binding SelectedSave.SummaryStats}" ItemTemplate="{StaticResource HeroMetricTemplate}" HorizontalAlignment="Stretch">
                            <ItemsRepeater.Layout>
                                <UniformGridLayout MinItemWidth="130" MinColumnSpacing="18" MinRowSpacing="10" ItemsStretch="Fill" ItemsJustification="Start" />
                            </ItemsRepeater.Layout>
                        </ItemsRepeater>
                    </Grid>
                </Border>

                <ItemsRepeater ItemsSource="{Binding SelectedSave.ProgressStats}" ItemTemplate="{StaticResource MetricTileTemplate}" HorizontalAlignment="Stretch">
                    <ItemsRepeater.Layout>
                        <UniformGridLayout MinItemWidth="136" MinColumnSpacing="10" MinRowSpacing="10" ItemsStretch="Fill" ItemsJustification="Start" />
                    </ItemsRepeater.Layout>
                </ItemsRepeater>

                <Grid x:Name="PrimaryGrid" ColumnSpacing="20" RowSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.05*" />
                        <ColumnDefinition Width="0.95*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel x:Name="PrimaryInfoColumn" Spacing="16">
                        <Border Style="{StaticResource CardStyle}" Padding="16">
                            <StackPanel Spacing="12">
                                <TextBlock Text="经营与农场" Style="{StaticResource SectionTitleStyle}" />
                                <ItemsRepeater ItemsSource="{Binding SelectedSave.EconomyStats}" ItemTemplate="{StaticResource MetricTileTemplate}" HorizontalAlignment="Stretch">
                                    <ItemsRepeater.Layout>
                                        <UniformGridLayout MinItemWidth="136" MinColumnSpacing="10" MinRowSpacing="10" ItemsStretch="Fill" ItemsJustification="Start" />
                                    </ItemsRepeater.Layout>
                                </ItemsRepeater>
                                <ItemsControl ItemsSource="{Binding SelectedSave.FarmLifeStats}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,4" ColumnSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="130" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Name}" Style="{StaticResource MutedTextStyle}" />
                                                <TextBlock Grid.Column="1" Text="{Binding Value}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardStyle}" Padding="16">
                            <StackPanel Spacing="10">
                                <TextBlock Text="技能" Style="{StaticResource SectionTitleStyle}" />
                                <ItemsControl ItemsSource="{Binding SelectedSave.Skills}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,5" ColumnSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="30" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Image Source="{Binding IconUri}" Width="28" Height="28" Stretch="Uniform" VerticalAlignment="Center" />
                                                <StackPanel Grid.Column="1">
                                                    <Grid>
                                                        <TextBlock Text="{Binding Name}" />
                                                        <TextBlock Text="{Binding LevelText}" HorizontalAlignment="Right" Foreground="{StaticResource AccentBrush}" />
                                                    </Grid>
                                                    <ProgressBar Value="{Binding Percent}" Maximum="100" Height="7" Margin="0,5,0,0" Foreground="{StaticResource AccentBrush}" />
                                                    <TextBlock Text="{Binding ExperienceText}" Style="{StaticResource MutedTextStyle}" Margin="0,4,0,0" />
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel x:Name="ProgressColumn" Grid.Column="1" Spacing="16">
                        <Border Style="{StaticResource CardStyle}" Padding="16">
                            <StackPanel Spacing="10">
                                <Grid>
                                    <TextBlock Text="完美度统计" Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="{Binding SelectedSave.PerfectionProgressDisplay}" HorizontalAlignment="Right" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" />
                                </Grid>
                                <ItemsRepeater ItemsSource="{Binding SelectedSave.PerfectionStats}" ItemTemplate="{StaticResource CompactProgressTileTemplate}" HorizontalAlignment="Stretch">
                                    <ItemsRepeater.Layout>
                                        <UniformGridLayout MinItemWidth="132" MinColumnSpacing="10" MinRowSpacing="10" ItemsStretch="Fill" ItemsJustification="Start" />
                                    </ItemsRepeater.Layout>
                                </ItemsRepeater>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardStyle}" Padding="16">
                            <StackPanel Spacing="10">
                                <TextBlock Text="收集品进度" Style="{StaticResource SectionTitleStyle}" />
                                <ItemsRepeater ItemsSource="{Binding SelectedSave.CollectionStats}" ItemTemplate="{StaticResource CompactProgressTileTemplate}" HorizontalAlignment="Stretch">
                                    <ItemsRepeater.Layout>
                                        <UniformGridLayout MinItemWidth="132" MinColumnSpacing="10" MinRowSpacing="10" ItemsStretch="Fill" ItemsJustification="Start" />
                                    </ItemsRepeater.Layout>
                                </ItemsRepeater>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <TextBlock Text="明细数据" Style="{StaticResource SectionTitleStyle}" Margin="0,4,0,-4" />
                <Grid x:Name="DetailGrid" ColumnSpacing="20" RowSpacing="16" HorizontalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.05*" />
                        <ColumnDefinition Width="0.95*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel x:Name="DetailStatsColumn" Spacing="16">
                        <Border Style="{StaticResource CardStyle}" Padding="16">
                            <StackPanel Spacing="12">
                                <TextBlock Text="详细统计" Style="{StaticResource SectionTitleStyle}" />
                                <ItemsRepeater ItemsSource="{Binding SelectedSave.ActivityStats}" ItemTemplate="{StaticResource MetricTileTemplate}" HorizontalAlignment="Stretch">
                                    <ItemsRepeater.Layout>
                                        <UniformGridLayout MinItemWidth="136" MinColumnSpacing="10" MinRowSpacing="10" ItemsStretch="Fill" ItemsJustification="Start" />
                                    </ItemsRepeater.Layout>
                                </ItemsRepeater>
                            </StackPanel>
                        </Border>

                        <Grid x:Name="CatchGrid" ColumnSpacing="16" RowSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Border x:Name="FishPanel" Style="{StaticResource CardStyle}" Padding="16">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="捕获的鱼类" Style="{StaticResource SectionTitleStyle}" />
                                    <ItemsRepeater ItemsSource="{Binding SelectedSave.FishCatchStats}" ItemTemplate="{StaticResource CatchTileTemplate}" HorizontalAlignment="Stretch">
                                        <ItemsRepeater.Layout>
                                            <UniformGridLayout MinItemWidth="118" MinColumnSpacing="8" MinRowSpacing="8" ItemsStretch="Fill" ItemsJustification="Start" />
                                        </ItemsRepeater.Layout>
                                    </ItemsRepeater>
                                </StackPanel>
                            </Border>
                            <Border x:Name="MonsterPanel" Grid.Column="1" Style="{StaticResource CardStyle}" Padding="16">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="杀死的怪物" Style="{StaticResource SectionTitleStyle}" />
                                    <ItemsRepeater ItemsSource="{Binding SelectedSave.MonsterKillStats}" ItemTemplate="{StaticResource CatchTileTemplate}" HorizontalAlignment="Stretch">
                                        <ItemsRepeater.Layout>
                                            <UniformGridLayout MinItemWidth="118" MinColumnSpacing="8" MinRowSpacing="8" ItemsStretch="Fill" ItemsJustification="Start" />
                                        </ItemsRepeater.Layout>
                                    </ItemsRepeater>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>

                    <Border x:Name="FriendshipPanel" Grid.Column="1" Style="{StaticResource CardStyle}" Padding="16">
                        <StackPanel Spacing="10">
                            <TextBlock Text="好感明细" Style="{StaticResource SectionTitleStyle}" />
                            <ItemsControl ItemsSource="{Binding SelectedSave.Friendships}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,5" ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="34" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Image Source="{Binding IconUri}" Width="32" Height="32" Stretch="UniformToFill" VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="1">
                                                <StackPanel Orientation="Horizontal" Spacing="5">
                                                    <TextBlock Text="{Binding Name}" />
                                                    <TextBlock Text="{Binding RelationshipText}" Foreground="{StaticResource AccentBrush}" />
                                                </StackPanel>
                                                <ItemsControl ItemsSource="{Binding HeartSlots}" Margin="0,5,0,0">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal" Spacing="1" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Width="24" Height="20">
                                                                <Image Source="{Binding IconUri}" Width="24" Height="20" Stretch="Fill" Opacity="{Binding HeartOpacity}" />
                                                                <Image Source="{Binding FullIconUri}" Width="24" Height="20" Stretch="Fill" Visibility="{Binding PartialVisibility}">
                                                                    <Image.Clip>
                                                                        <RectangleGeometry Rect="0,0,24,20">
                                                                            <RectangleGeometry.Transform>
                                                                                <ScaleTransform ScaleX="{Binding FillPercent}" CenterX="0" />
                                                                            </RectangleGeometry.Transform>
                                                                        </RectangleGeometry>
                                                                    </Image.Clip>
                                                                </Image>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
