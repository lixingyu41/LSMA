<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Name="ModsPageRoot"
    x:Class="LSMA.Pages.ModsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="30,16,30,24" RowSpacing="10" AllowDrop="True" DragOver="Package_DragOver" Drop="Package_Drop">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <ProgressRing IsActive="{Binding IsBusy}" Width="19" Height="19" />
                    <TextBlock Text="{Binding TaskStatus}" Style="{StaticResource BodyTextStyle}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding FeedbackMessage}" Foreground="{StaticResource SuccessBrush}" VerticalAlignment="Center" />
                </StackPanel>
                <CommandBar Grid.Column="1" Style="{StaticResource TopBarCommandBarStyle}" HorizontalAlignment="Right">
                    <AppBarButton Label="安装模组" Command="{Binding ChoosePackageCommand}">
                        <AppBarButton.Icon><FontIcon Glyph="&#xE710;" /></AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton Label="检查更新" Command="{Binding CheckUpdatesCommand}">
                        <AppBarButton.Icon><FontIcon Glyph="&#xE895;" /></AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton Label="模组包" Command="{Binding ToggleModPackPanelCommand}">
                        <AppBarButton.Icon><FontIcon Glyph="&#xE8B7;" /></AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton Label="备份目录" Command="{Binding OpenBackupsCommand}">
                        <AppBarButton.Icon><FontIcon Glyph="&#xE8A7;" /></AppBarButton.Icon>
                    </AppBarButton>
                </CommandBar>
            </Grid>

            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Visibility="{Binding UnavailableVisibility}">
                <StackPanel Spacing="10">
                    <TextBlock Text="模组管理暂不可用" Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="请先在设置中连接游戏目录。" Style="{StaticResource BodyTextStyle}" />
                </StackPanel>
            </Border>

                <InfoBar Grid.Row="1" IsOpen="True" Severity="Warning" IsClosable="False" Title="修改操作已暂停"
                         Message="游戏正在运行。为避免损坏文件，当前只能查看模组信息。"
                         Visibility="{Binding RunningVisibility}" />

                <Border Grid.Row="2" Style="{StaticResource CardStyle}" Visibility="{Binding PlanVisibility}">
                    <StackPanel Spacing="12">
                        <Grid>
                            <StackPanel Spacing="3">
                                <TextBlock Text="安装计划" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="{Binding PendingPlan.PackageName}" Style="{StaticResource MutedTextStyle}" />
                                <TextBlock Text="{Binding PendingPlan.Summary}" Foreground="{StaticResource AccentBrush}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="9" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Button Content="取消" Command="{Binding CancelPackageCommand}" Style="{StaticResource NeutralButtonStyle}" />
                                <Button Content="确认安装" Command="{Binding InstallPackageCommand}" Style="{StaticResource DangerButtonStyle}" />
                            </StackPanel>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding PendingPlan.Items}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="0,1,0,0" Padding="0,10">
                                        <Grid>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding SafetyText}" Style="{StaticResource MutedTextStyle}" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding ActionText}" HorizontalAlignment="Right" Foreground="{StaticResource AccentBrush}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <ItemsControl ItemsSource="{Binding PendingPlan.Blockers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate><TextBlock Text="{Binding}" Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap" /></DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <ItemsControl ItemsSource="{Binding PendingPlan.Warnings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate><TextBlock Text="{Binding}" Foreground="{StaticResource WarningBrush}" TextWrapping="Wrap" /></DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="{Binding PendingPlan.MissingDependencySummary}" Foreground="{StaticResource WarningBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource CardStyle}" Visibility="{Binding MissingDependencyPanelVisibility}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="待补齐前置" Style="{StaticResource SectionTitleStyle}" />
                        <ItemsControl ItemsSource="{Binding MissingDependencies}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnSpacing="10" Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding DetailText}" TextWrapping="Wrap" VerticalAlignment="Center" />
                                        <Button Grid.Column="1"
                                                Content="{Binding ButtonText}"
                                                Command="{Binding DataContext.InstallMissingDependencyCommand, ElementName=ModsPageRoot}"
                                                CommandParameter="{Binding}"
                                                IsEnabled="{Binding CanDownload}"
                                                Style="{StaticResource SubtleButtonStyle}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Row="3" CornerRadius="16" Background="{ThemeResource CardBackgroundBrush}"
                        Padding="0" Margin="-5,0" Visibility="{Binding FilterAndListVisibility}">
                    <Grid x:Name="FilterContainer">
                        <!-- Button grid -->
                        <Grid x:Name="FilterButtonGrid">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Selection pill (inside the same grid, fills one column) -->
                            <Border x:Name="FilterSelectionPill"
                                    Background="{StaticResource AccentBrush}"
                                    CornerRadius="20"
                                    HorizontalAlignment="Stretch"
                                    RenderTransformOrigin="0.0,0.5"
                                    Visibility="Collapsed">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="PillTransform" />
                                </Border.RenderTransform>
                            </Border>
                            <Button x:Name="AllFilterButton" Style="{StaticResource FilterPillButtonStyle}"
                                    Command="{Binding FilterCommand}" CommandParameter="全部">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="0.3*" />
                                        <ColumnDefinition Width="0.4*" />
                                        <ColumnDefinition Width="0.3*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="所有" Style="{StaticResource MutedTextStyle}" VerticalAlignment="Top" HorizontalAlignment="Left" />
                                        <TextBlock Grid.Column="1" Text="{Binding InstalledCount}" FontSize="29" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    </Grid>
                                </Grid>
                            </Button>
                            <Button x:Name="UpdateFilterButton" Grid.Column="1" Style="{StaticResource FilterPillButtonStyle}"
                                    Command="{Binding FilterCommand}" CommandParameter="可更新">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="0.3*" />
                                        <ColumnDefinition Width="0.4*" />
                                        <ColumnDefinition Width="0.3*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="可更新" Style="{StaticResource MutedTextStyle}" VerticalAlignment="Top" HorizontalAlignment="Left" />
                                        <TextBlock Grid.Column="1" Text="{Binding UpdateCount}" FontSize="29" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    </Grid>
                                </Grid>
                            </Button>
                            <Button x:Name="ProblemFilterButton" Grid.Column="2" Style="{StaticResource FilterPillButtonStyle}"
                                    Command="{Binding FilterCommand}" CommandParameter="有问题">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="0.3*" />
                                        <ColumnDefinition Width="0.4*" />
                                        <ColumnDefinition Width="0.3*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="有问题" Style="{StaticResource MutedTextStyle}" VerticalAlignment="Top" HorizontalAlignment="Left" />
                                        <TextBlock x:Name="ProblemCountText" Grid.Column="1" Text="{Binding ProblemCount}" FontSize="29" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    </Grid>
                                </Grid>
                            </Button>
                            <Button x:Name="DisabledFilterButton" Grid.Column="3" Style="{StaticResource FilterPillButtonStyle}"
                                    Command="{Binding FilterCommand}" CommandParameter="已禁用">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="0.3*" />
                                        <ColumnDefinition Width="0.4*" />
                                        <ColumnDefinition Width="0.3*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="已禁用" Style="{StaticResource MutedTextStyle}" VerticalAlignment="Top" HorizontalAlignment="Left" />
                                        <TextBlock Grid.Column="1" Text="{Binding DisabledCount}" FontSize="27" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    </Grid>
                                </Grid>
                            </Button>
                            <Button x:Name="FavoriteFilterButton" Grid.Column="4" Style="{StaticResource FilterPillButtonStyle}"
                                    Command="{Binding FilterCommand}" CommandParameter="收藏">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="0.3*" />
                                        <ColumnDefinition Width="0.4*" />
                                        <ColumnDefinition Width="0.3*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="收藏" Style="{StaticResource MutedTextStyle}" VerticalAlignment="Top" HorizontalAlignment="Left" />
                                        <TextBlock Grid.Column="1" Text="{Binding FavoriteCount}" FontSize="29" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    </Grid>
                                </Grid>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="3" Grid.RowSpan="2" Style="{StaticResource CardStyle}" Visibility="{Binding ModPackPanelVisibility}">
                    <Grid ColumnSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="330" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel Spacing="3">
                                <TextBlock Text="模组包" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="切换时会物理换入 / 换出 Mods 目录。" Style="{StaticResource MutedTextStyle}" />
                            </StackPanel>
                            <ListView Grid.Row="1"
                                      ItemsSource="{Binding ModPacks}"
                                      SelectedItem="{Binding SelectedModPack, Mode=TwoWay}"
                                      SelectionMode="Single">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Padding="8,6" Spacing="3">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding StatusText}" Style="{StaticResource MutedTextStyle}" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
                                <Button Content="新建空包" Command="{Binding CreateModPackCommand}" Style="{StaticResource SubtleButtonStyle}" />
                                <Button Content="导入新包" Command="{Binding ImportModPackCommand}" Style="{StaticResource SubtleButtonStyle}" />
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Column="1" RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid>
                                <StackPanel Spacing="3">
                                    <TextBlock Text="{Binding SelectedModPackTitle}" Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="{Binding SelectedModPackStatus}" Style="{StaticResource MutedTextStyle}" />
                                </StackPanel>
                                <Button Content="关闭" Command="{Binding ToggleModPackPanelCommand}" Style="{StaticResource NeutralButtonStyle}" HorizontalAlignment="Right" />
                            </Grid>
                            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" HorizontalScrollMode="Enabled" VerticalScrollBarVisibility="Disabled" VerticalScrollMode="Disabled">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="切换到此包" Command="{Binding SwitchModPackCommand}" Style="{StaticResource AccentButtonStyle}" />
                                    <Button Content="复制当前 Mods" Command="{Binding CaptureCurrentModsCommand}" Style="{StaticResource SubtleButtonStyle}" />
                                    <Button Content="重命名" Command="{Binding RenameModPackCommand}" Style="{StaticResource SubtleButtonStyle}" />
                                    <Button Content="合并导入" Command="{Binding MergeModPackCommand}" Style="{StaticResource SubtleButtonStyle}" />
                                    <Button Content="下载缺失" Command="{Binding DownloadMissingModPackFilesCommand}" Style="{StaticResource SubtleButtonStyle}" />
                                    <Button Content="导出带文件" Command="{Binding ExportModPackWithFilesCommand}" Style="{StaticResource SubtleButtonStyle}" />
                                    <Button Content="导出轻量" Command="{Binding ExportModPackMetadataCommand}" Style="{StaticResource SubtleButtonStyle}" />
                                    <Button Content="删除" Command="{Binding DeleteModPackCommand}" Style="{StaticResource DangerButtonStyle}" />
                                </StackPanel>
                            </ScrollViewer>
                            <ListView Grid.Row="2"
                                      ItemsSource="{Binding ModPackEntries}"
                                      Visibility="{Binding SelectedModPackVisibility}">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="8,6" ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="160" />
                                                <ColumnDefinition Width="220" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Spacing="3">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding UniqueId}" Style="{StaticResource MutedTextStyle}" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding Version}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" Text="{Binding NexusText}" Style="{StaticResource MutedTextStyle}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="3" Text="{Binding FileStatusText}" VerticalAlignment="Center" TextWrapping="Wrap" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Grid>
                </Border>

                <Grid x:Name="ModsSplitGrid" Grid.Row="4" MinHeight="250" Visibility="{Binding FilterAndListVisibility}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="ModsListColumn" Width="640" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition x:Name="ModsDetailColumn" Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid>
                        <Border Style="{StaticResource CardStyle}" Padding="8">
                            <ListView ItemsSource="{Binding Mods}" SelectedItem="{Binding SelectedMod, Mode=TwoWay}" SelectionMode="Single">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="0" />
                                        <Setter Property="MinHeight" Value="0" />
                                        <Setter Property="UseSystemFocusVisuals" Value="False" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListViewItem">
                                                    <ContentPresenter Content="{TemplateBinding Content}"
                                                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,4,8,4"
                                              MinHeight="116"
                                              PointerEntered="ModListItem_PointerEntered"
                                              PointerExited="ModListItem_PointerExited">
                                            <Border Background="{ThemeResource CardBackgroundBrush}"
                                                    BorderBrush="{ThemeResource CardBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8" />
                                            <Border Background="{ThemeResource AccentSoftBrush}"
                                                    CornerRadius="8"
                                                    Opacity="{Binding HoverLayerOpacity}" />
                                            <Border Background="{ThemeResource AccentSoftBrush}"
                                                    CornerRadius="8"
                                                    Opacity="{Binding SelectedLayerOpacity}" />
                                            <Grid Padding="10,10" ColumnSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="128" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="112" />
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0"
                                                        Width="128"
                                                        Height="82"
                                                        Background="{ThemeResource AccentSoftBrush}"
                                                        BorderBrush="{ThemeResource CardBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="6"
                                                        VerticalAlignment="Top"
                                                        Tapped="ModCover_Tapped"
                                                        ToolTipService.ToolTip="预览封面">
                                                    <Grid>
                                                        <Image Source="{Binding CoverImageUri}" Stretch="Uniform" Visibility="{Binding CoverImageVisibility}" />
                                                        <FontIcon Glyph="&#xEB9F;" FontSize="24" Opacity="0.5" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding CoverPlaceholderVisibility}" />
                                                    </Grid>
                                                </Border>
                                                <StackPanel Grid.Column="1" Spacing="4">
                                                    <TextBlock Text="{Binding DisplayName}" Foreground="{Binding ListTextBrush}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding RemoteCategoryText}" Foreground="{Binding ListTextBrush}" FontSize="14" Opacity="0.72" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding DisplayDescription}" Foreground="{Binding ListTextBrush}" FontSize="14" Opacity="0.72" TextWrapping="WrapWholeWords" MaxLines="3" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" HorizontalAlignment="Right" Spacing="8">
                                                    <TextBlock Text="{Binding ListNexusIdText}" Foreground="{Binding ListTextBrush}" FontSize="14" Opacity="0.72" HorizontalAlignment="Right" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding RemoteUpdatedText}" Foreground="{Binding ListTextBrush}" FontSize="14" Opacity="0.72" HorizontalAlignment="Right" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding RemoteDownloadsText}" Foreground="{Binding ListTextBrush}" HorizontalAlignment="Right" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Border>
                        <Border x:Name="ModCoverPreviewOverlay"
                                Background="#B0000000"
                                Visibility="Collapsed"
                                IsTabStop="True"
                                KeyDown="ModCoverPreviewOverlay_KeyDown"
                                Tapped="ModCoverPreviewOverlay_Tapped">
                            <Grid>
                                <Image x:Name="ModCoverPreviewImage"
                                       Stretch="Uniform"
                                       MaxWidth="620"
                                       MaxHeight="620"
                                       PointerPressed="ModCoverPreviewImage_PointerPressed"
                                       PointerMoved="ModCoverPreviewImage_PointerMoved"
                                       PointerReleased="ModCoverPreviewImage_PointerReleased"
                                       PointerCanceled="ModCoverPreviewImage_PointerReleased"
                                       PointerWheelChanged="ModCoverPreviewImage_PointerWheelChanged"
                                       Tapped="ModCoverPreviewImage_Tapped">
                                    <Image.RenderTransform>
                                        <CompositeTransform x:Name="ModCoverPreviewTransform" />
                                    </Image.RenderTransform>
                                </Image>
                            </Grid>
                        </Border>
                    </Grid>

                    <Border x:Name="ModsSplitter"
                            Grid.Column="1"
                            Width="14"
                            Background="Transparent"
                            PointerPressed="ModsSplitter_PointerPressed"
                            PointerMoved="ModsSplitter_PointerMoved"
                            PointerReleased="ModsSplitter_PointerReleased"
                            PointerCanceled="ModsSplitter_PointerReleased">
                        <Border Width="2"
                                HorizontalAlignment="Center"
                                Background="{ThemeResource CardBorderBrush}"
                                CornerRadius="1" />
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                        <ScrollViewer Visibility="{Binding DetailVisibility}">
                            <StackPanel Spacing="12">
                                <!-- Title row: name + action buttons -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding SelectedMod.DisplayName}" Style="{StaticResource SectionTitleStyle}" TextWrapping="Wrap" TextTrimming="None" />
                                        <TextBlock Text="{Binding SelectedMod.OriginalDescriptionText}" Style="{StaticResource BodyTextStyle}" Visibility="{Binding SelectedMod.OriginalDescriptionVisibility}" TextWrapping="Wrap" TextTrimming="None" />
                                        <TextBlock Text="{Binding SelectedMod.TranslatedDescriptionText}" Style="{StaticResource BodyTextStyle}" Visibility="{Binding SelectedMod.TranslatedDescriptionVisibility}" TextWrapping="Wrap" TextTrimming="None" Margin="0,6,0,0" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Top">
                                        <Button Content="启用" Command="{Binding EnableCommand}" Style="{StaticResource AccentButtonStyle}" Visibility="{Binding EnableVisibility}" />
                                        <Button Content="禁用" Command="{Binding DisableCommand}" Style="{StaticResource DangerButtonStyle}" Visibility="{Binding DisableVisibility}" />
                                        <Button Content="备份" Command="{Binding BackupCommand}" Style="{StaticResource SubtleButtonStyle}" />
                                        <Button Content="获取更新" Command="{Binding PrepareSelectedUpdateCommand}" Style="{StaticResource SubtleButtonStyle}" />
                                        <Button Content="打开N网" Command="{Binding OpenSelectedNexusPageCommand}" Style="{StaticResource SubtleButtonStyle}" Visibility="{Binding OpenNexusPageVisibility}" />
                                    </StackPanel>
                                </Grid>

                                <!-- Info grid -->
                                <Grid ColumnSpacing="18">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="作者" Style="{StaticResource MutedTextStyle}" />
                                        <TextBlock x:Name="AuthorText"
                                                   Text="{Binding SelectedMod.Author}"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   ToolTipService.ToolTip="打开 Nexus 作者页"
                                                   Tapped="AuthorText_Tapped" />
                                        <TextBlock Text="模组识别名" Style="{StaticResource MutedTextStyle}" Margin="0,8,0,0" /><TextBlock Text="{Binding SelectedMod.UniqueId}" />
                                        <StackPanel Visibility="{Binding DependencySectionVisibility}">
                                            <TextBlock Text="前置模组" Style="{StaticResource MutedTextStyle}" Margin="0,8,0,0" />
                                            <TextBlock Text="{Binding SelectedMod.DependencyText}" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <TextBlock Text="版本" Style="{StaticResource MutedTextStyle}" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding SelectedMod.Version}" VerticalAlignment="Center" />
                                            <StackPanel x:Name="NexusIdContainer" Grid.Column="1" Orientation="Horizontal"
                                                        HorizontalAlignment="Right" Spacing="4"
                                                        PointerEntered="NexusIdContainer_PointerEntered"
                                                        PointerExited="NexusIdContainer_PointerExited">
                                                <Button x:Name="NexusIdEditButton"
                                                        Content="修改" Command="{Binding EditNexusBindingCommand}"
                                                        Style="{StaticResource SubtleButtonStyle}"
                                                        Visibility="Collapsed"
                                                        MinWidth="40" MinHeight="24" Padding="8,2" />
                                                <TextBlock x:Name="NexusIdText"
                                                           Text="{Binding NexusIdDisplayText}"
                                                           Style="{StaticResource MutedTextStyle}"
                                                           VerticalAlignment="Center" MinHeight="24"
                                                           ToolTipService.ToolTip="点击复制"
                                                           Tapped="NexusIdText_Tapped" />
                                            </StackPanel>
                                        </Grid>
                                        <TextBlock Text="状态" Style="{StaticResource MutedTextStyle}" Margin="0,8,0,0" /><TextBlock Text="{Binding SelectedMod.StatusText}" />
                                        <StackPanel Visibility="{Binding DependencySectionVisibility}">
                                            <TextBlock Text="前置状态" Style="{StaticResource MutedTextStyle}" Margin="0,8,0,0" /><TextBlock Text="{Binding SelectedMod.DependencyStatus}" />
                                        </StackPanel>
                                        <TextBlock Text="更新来源" Style="{StaticResource MutedTextStyle}" Margin="0,8,0,0" /><TextBlock Text="{Binding SelectedMod.UpdateSourceText}" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding SelectedMod.UpdateStatus}" Foreground="{StaticResource AccentBrush}" Margin="0,5,0,0" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>

                                <!-- File path - full width -->
                                <StackPanel>
                                    <TextBlock Text="文件位置" Style="{StaticResource MutedTextStyle}" />
                                    <TextBlock x:Name="FolderPathText"
                                               Text="{Binding SelectedMod.FolderPath}"
                                               Style="{StaticResource BodyTextStyle}"
                                               TextWrapping="Wrap"
                                               ToolTipService.ToolTip="点击复制路径，右键打开文件夹"
                                               Tapped="FolderPathText_Tapped"
                                               RightTapped="FolderPathText_RightTapped" />
                                </StackPanel>

                                <!-- Issues -->
                                <StackPanel Visibility="{Binding IssuesSectionVisibility}">
                                    <TextBlock Text="发现的问题" Style="{StaticResource SectionTitleStyle}" Margin="0,8,0,0" />
                                    <ItemsControl ItemsSource="{Binding SelectedMod.Issues}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Message}" Foreground="{StaticResource DangerBrush}" Margin="0,4" TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                                <TextBlock Visibility="{Binding NoNexusIdMessageVisibility}"
                                           Style="{StaticResource MutedTextStyle}"
                                           TextWrapping="Wrap"
                                           Text="未绑定 Nexus Mod ID，点击右上角「手动匹配ID」进行绑定。" />

                                <!-- Nexus binding editor -->
                                <StackPanel Orientation="Horizontal" Spacing="8" Visibility="{Binding NexusBindingEditorVisibility}">
                                    <TextBox Text="{Binding NexusModIdInput, Mode=TwoWay}" PlaceholderText="绑定 Nexus Mod ID" Width="180" />
                                    <Button Content="保存绑定" Command="{Binding BindNexusIdCommand}" Style="{StaticResource SubtleButtonStyle}" />
                                    <Button Content="取消" Command="{Binding EditNexusBindingCommand}" Style="{StaticResource SubtleButtonStyle}" Visibility="{Binding CancelNexusBindingVisibility}" />
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
    </Grid>
</Page>
