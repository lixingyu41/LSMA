<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="LSMA.Pages.ModsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="30,16,30,24" RowSpacing="14" AllowDrop="True" DragOver="Package_DragOver" Drop="Package_Drop">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
            <CommandBar Grid.Row="0" Background="Transparent" DefaultLabelPosition="Right" IsDynamicOverflowEnabled="True">
                <AppBarButton Label="安装模组" Command="{Binding ChoosePackageCommand}">
                    <AppBarButton.Icon><FontIcon Glyph="&#xE710;" /></AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton Label="检查更新" Command="{Binding CheckUpdatesCommand}">
                    <AppBarButton.Icon><FontIcon Glyph="&#xE895;" /></AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton Label="发现" Command="{Binding BrowseCommand}" CommandParameter="趋势">
                    <AppBarButton.Icon><FontIcon Glyph="&#xE721;" /></AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton Label="收藏" Command="{Binding ShowFavoritesCommand}">
                    <AppBarButton.Icon><FontIcon Glyph="&#xE734;" /></AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton Label="下载" Command="{Binding ShowDownloadsCommand}">
                    <AppBarButton.Icon><FontIcon Glyph="&#xE896;" /></AppBarButton.Icon>
                </AppBarButton>
            </CommandBar>

            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Visibility="{Binding UnavailableVisibility}">
                <StackPanel Spacing="10">
                    <TextBlock Text="模组管理暂不可用" Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="请先在首页或设置中连接游戏目录。" Style="{StaticResource BodyTextStyle}" />
                </StackPanel>
            </Border>

                <InfoBar Grid.Row="1" IsOpen="True" Severity="Warning" IsClosable="False" Title="修改操作已暂停"
                         Message="游戏正在运行。为避免损坏文件，当前只能查看模组信息。"
                         Visibility="{Binding RunningVisibility}" />

                <Border Grid.Row="2" Style="{StaticResource CardStyle}" Visibility="{Binding PlanVisibility}">
                    <StackPanel Spacing="12">
                        <Grid>
                            <StackPanel Spacing="3">
                                <TextBlock Text="安装计划" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="{Binding PendingPlan.PackageName}" Style="{StaticResource MutedTextStyle}" />
                                <TextBlock Text="{Binding PendingPlan.Summary}" Foreground="{StaticResource AccentBrush}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="9" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Button Content="取消" Command="{Binding CancelPackageCommand}" Style="{StaticResource NeutralButtonStyle}" />
                                <Button Content="确认安装" Command="{Binding InstallPackageCommand}" Style="{StaticResource DangerButtonStyle}" />
                            </StackPanel>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding PendingPlan.Items}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="0,1,0,0" Padding="0,10">
                                        <Grid>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding SafetyText}" Style="{StaticResource MutedTextStyle}" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding ActionText}" HorizontalAlignment="Right" Foreground="{StaticResource AccentBrush}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <ItemsControl ItemsSource="{Binding PendingPlan.Blockers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate><TextBlock Text="{Binding}" Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap" /></DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <ItemsControl ItemsSource="{Binding PendingPlan.Warnings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate><TextBlock Text="{Binding}" Foreground="{StaticResource WarningBrush}" TextWrapping="Wrap" /></DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Row="3" Style="{StaticResource CardStyle}" Visibility="{Binding OnlinePanelVisibility}">
                    <StackPanel Spacing="13">
                        <Grid>
                            <TextBlock Text="{Binding OnlinePanelTitle}" Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock Text="{Binding RateLimitText}" HorizontalAlignment="Right" Style="{StaticResource MutedTextStyle}" />
                        </Grid>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="趋势" Command="{Binding BrowseCommand}" CommandParameter="趋势" Style="{StaticResource SubtleButtonStyle}" />
                            <Button Content="最新" Command="{Binding BrowseCommand}" CommandParameter="最新" Style="{StaticResource SubtleButtonStyle}" />
                            <Button Content="最近更新" Command="{Binding BrowseCommand}" CommandParameter="最近更新" Style="{StaticResource SubtleButtonStyle}" />
                            <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory, Mode=TwoWay}" DisplayMemberPath="Name" PlaceholderText="分类" Width="130" />
                            <TextBox Text="{Binding OnlineQuery, Mode=TwoWay}" PlaceholderText="筛选已加载结果" Width="220" />
                            <Button Content="筛选" Command="{Binding SearchOnlineCommand}" Style="{StaticResource SubtleButtonStyle}" />
                            <Button Content="最多支持" Command="{Binding SortOnlineCommand}" CommandParameter="最多支持" Style="{StaticResource SubtleButtonStyle}" />
                            <Button Content="最多下载" Command="{Binding SortOnlineCommand}" CommandParameter="最多下载" Style="{StaticResource SubtleButtonStyle}" />
                            <Button Content="返回已安装" Command="{Binding ShowInstalledCommand}" Style="{StaticResource SubtleButtonStyle}" />
                        </StackPanel>
                        <Grid ColumnSpacing="14" MaxHeight="280">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="315" /></Grid.ColumnDefinitions>
                            <ListView ItemsSource="{Binding OnlineMods}" SelectedItem="{Binding SelectedOnlineMod, Mode=TwoWay}">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Padding="7" Spacing="3">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Author}" Style="{StaticResource MutedTextStyle}" />
                                            <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource AccentBrush}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                            <StackPanel Grid.Column="1" Spacing="8">
                                <TextBlock Text="{Binding SelectedOnlineMod.Name}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding SelectedOnlineMod.Summary}" Style="{StaticResource BodyTextStyle}" MaxHeight="60" />
                                <StackPanel Orientation="Horizontal" Spacing="7">
                                    <Button Content="收藏/取消" Command="{Binding ToggleFavoriteCommand}" Style="{StaticResource SubtleButtonStyle}" />
                                    <Button Content="打开 Nexus" Command="{Binding OpenNexusCommand}" Style="{StaticResource SubtleButtonStyle}" />
                                </StackPanel>
                                <Button Content="选择下载文件" Command="{Binding LoadFilesCommand}" Style="{StaticResource SubtleButtonStyle}" HorizontalAlignment="Left" />
                                <ComboBox ItemsSource="{Binding OnlineFiles}" SelectedItem="{Binding SelectedOnlineFile, Mode=TwoWay}" DisplayMemberPath="DisplayText" PlaceholderText="选择文件" MinWidth="280" />
                                <Button Content="下载并预检" Command="{Binding DownloadFileCommand}" Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Left" />
                                <Button Content="取消下载" Command="{Binding CancelDownloadCommand}" Style="{StaticResource NeutralButtonStyle}" HorizontalAlignment="Left" />
                            </StackPanel>
                        </Grid>
                        <Expander Header="本地收藏">
                            <StackPanel Spacing="8" Margin="0,8,0,0">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="导入 JSON" Command="{Binding ImportFavoritesCommand}" Style="{StaticResource SubtleButtonStyle}" />
                                    <Button Content="导出 JSON" Command="{Binding ExportFavoritesCommand}" Style="{StaticResource SubtleButtonStyle}" />
                                </StackPanel>
                                <ItemsControl ItemsSource="{Binding Favorites}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,3">
                                                <TextBlock Text="{Binding Name}" />
                                                <TextBlock Text="{Binding Version}" HorizontalAlignment="Right" Foreground="{StaticResource AccentBrush}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Expander>
                        <Expander Header="下载队列">
                            <ItemsControl ItemsSource="{Binding DownloadQueue}" Margin="0,8,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,4">
                                            <TextBlock Text="{Binding ModName}" />
                                            <TextBlock Text="{Binding StatusText}" HorizontalAlignment="Right" Foreground="{StaticResource AccentBrush}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Expander>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="4" ColumnSpacing="10" Visibility="{Binding AvailableVisibility}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel><TextBlock Text="已安装" Style="{StaticResource MutedTextStyle}" /><TextBlock Text="{Binding InstalledCount}" FontSize="27" FontWeight="SemiBold" /></StackPanel>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                        <StackPanel><TextBlock Text="正常" Style="{StaticResource MutedTextStyle}" /><TextBlock Text="{Binding HealthyCount}" FontSize="27" FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}" /></StackPanel>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                        <StackPanel><TextBlock Text="可更新" Style="{StaticResource MutedTextStyle}" /><TextBlock Text="{Binding UpdateCount}" FontSize="27" FontWeight="SemiBold" /></StackPanel>
                    </Border>
                    <Border Grid.Column="3" Style="{StaticResource CardStyle}">
                        <StackPanel><TextBlock Text="缺前置" Style="{StaticResource MutedTextStyle}" /><TextBlock Text="{Binding MissingDependencyCount}" FontSize="27" FontWeight="SemiBold" Foreground="{StaticResource WarningBrush}" /></StackPanel>
                    </Border>
                    <Border Grid.Column="4" Style="{StaticResource CardStyle}">
                        <StackPanel><TextBlock Text="有问题" Style="{StaticResource MutedTextStyle}" /><TextBlock Text="{Binding ProblemCount}" FontSize="27" FontWeight="SemiBold" Foreground="{StaticResource DangerBrush}" /></StackPanel>
                    </Border>
                    <Border Grid.Column="5" Style="{StaticResource CardStyle}">
                        <StackPanel><TextBlock Text="已禁用" Style="{StaticResource MutedTextStyle}" /><TextBlock Text="{Binding DisabledCount}" FontSize="27" FontWeight="SemiBold" /></StackPanel>
                    </Border>
                </Grid>

                <StackPanel Grid.Row="5" Orientation="Horizontal" Spacing="8" Visibility="{Binding AvailableVisibility}">
                    <Button Content="全部" Command="{Binding FilterCommand}" CommandParameter="全部" Style="{StaticResource SubtleButtonStyle}" />
                    <Button Content="正常" Command="{Binding FilterCommand}" CommandParameter="正常" Style="{StaticResource SubtleButtonStyle}" />
                    <Button Content="可更新" Command="{Binding FilterCommand}" CommandParameter="可更新" Style="{StaticResource SubtleButtonStyle}" />
                    <Button Content="缺少前置" Command="{Binding FilterCommand}" CommandParameter="缺少前置" Style="{StaticResource SubtleButtonStyle}" />
                    <Button Content="有问题" Command="{Binding FilterCommand}" CommandParameter="有问题" Style="{StaticResource SubtleButtonStyle}" />
                    <Button Content="已禁用" Command="{Binding FilterCommand}" CommandParameter="已禁用" Style="{StaticResource SubtleButtonStyle}" />
                    <Button Content="收藏" Command="{Binding FilterCommand}" CommandParameter="收藏" Style="{StaticResource SubtleButtonStyle}" />
                    <Button Content="已归档" Command="{Binding FilterCommand}" CommandParameter="已归档" Style="{StaticResource SubtleButtonStyle}" />
                </StackPanel>

                <Grid Grid.Row="6" ColumnSpacing="14" MinHeight="250" Visibility="{Binding AvailableVisibility}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="430" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource CardStyle}" Padding="8">
                        <ListView ItemsSource="{Binding Mods}" SelectedItem="{Binding SelectedMod, Mode=TwoWay}" SelectionMode="Single">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="10,7" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                        <StackPanel Spacing="3">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Author}" Style="{StaticResource MutedTextStyle}" />
                                            <TextBlock Text="{Binding IssueSummary}" Style="{StaticResource MutedTextStyle}" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding Version}" Style="{StaticResource MutedTextStyle}" HorizontalAlignment="Right" />
                                            <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Right" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                        <ScrollViewer Visibility="{Binding DetailVisibility}">
                            <StackPanel Spacing="12">
                                <TextBlock Text="{Binding SelectedMod.Name}" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="{Binding SelectedMod.Manifest.Description}" Style="{StaticResource BodyTextStyle}" />
                                <Grid ColumnSpacing="18">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="作者" Style="{StaticResource MutedTextStyle}" /><TextBlock Text="{Binding SelectedMod.Author}" />
                                        <TextBlock Text="模组识别名" Style="{StaticResource MutedTextStyle}" Margin="0,8,0,0" /><TextBlock Text="{Binding SelectedMod.UniqueId}" />
                                        <TextBlock Text="前置模组" Style="{StaticResource MutedTextStyle}" Margin="0,8,0,0" /><TextBlock Text="{Binding SelectedMod.DependencyText}" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <TextBlock Text="版本" Style="{StaticResource MutedTextStyle}" /><TextBlock Text="{Binding SelectedMod.Version}" />
                                        <TextBlock Text="状态" Style="{StaticResource MutedTextStyle}" Margin="0,8,0,0" /><TextBlock Text="{Binding SelectedMod.StatusText}" />
                                        <TextBlock Text="前置状态" Style="{StaticResource MutedTextStyle}" Margin="0,8,0,0" /><TextBlock Text="{Binding SelectedMod.DependencyStatus}" />
                                        <TextBlock Text="更新来源" Style="{StaticResource MutedTextStyle}" Margin="0,8,0,0" /><TextBlock Text="{Binding SelectedMod.UpdateSourceText}" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding SelectedMod.UpdateStatus}" Foreground="{StaticResource AccentBrush}" Margin="0,5,0,0" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="发现的问题" Style="{StaticResource SectionTitleStyle}" Margin="0,8,0,0" />
                                <ItemsControl ItemsSource="{Binding SelectedMod.Issues}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Message}" Foreground="{StaticResource DangerBrush}" Margin="0,4" TextWrapping="Wrap" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Expander Header="文件位置">
                                    <TextBlock Text="{Binding SelectedMod.FolderPath}" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" Margin="0,8,0,0" />
                                </Expander>
                                <StackPanel Orientation="Horizontal" Spacing="8" Visibility="{Binding NexusBoundVisibility}">
                                    <TextBlock Text="{Binding NexusBindingText}" Style="{StaticResource MutedTextStyle}" VerticalAlignment="Center" />
                                    <Button Content="修改" Command="{Binding EditNexusBindingCommand}" Style="{StaticResource SubtleButtonStyle}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8" Visibility="{Binding NexusBindingEditorVisibility}">
                                    <TextBox Text="{Binding NexusModIdInput, Mode=TwoWay}" PlaceholderText="绑定 Nexus Mod ID" Width="180" />
                                    <Button Content="保存绑定" Command="{Binding BindNexusIdCommand}" Style="{StaticResource SubtleButtonStyle}" />
                                    <Button Content="取消" Command="{Binding EditNexusBindingCommand}" Style="{StaticResource SubtleButtonStyle}" Visibility="{Binding CancelNexusBindingVisibility}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="9" Margin="0,10,0,0">
                                    <Button Content="启用" Command="{Binding EnableCommand}" Style="{StaticResource AccentButtonStyle}" Visibility="{Binding EnableVisibility}" />
                                    <Button Content="禁用" Command="{Binding DisableCommand}" Style="{StaticResource DangerButtonStyle}" Visibility="{Binding DisableVisibility}" />
                                    <Button Content="获取更新文件" Command="{Binding PrepareSelectedUpdateCommand}" Style="{StaticResource SubtleButtonStyle}" />
                                </StackPanel>
                                <Expander Header="更多操作">
                                    <StackPanel Orientation="Horizontal" Spacing="9" Margin="0,8,0,0">
                                        <Button Content="备份" Command="{Binding BackupCommand}" Style="{StaticResource SubtleButtonStyle}" />
                                        <Button Content="归档" Command="{Binding ArchiveCommand}" Style="{StaticResource DangerButtonStyle}" Visibility="{Binding ArchiveVisibility}" />
                                        <Button Content="恢复归档" Command="{Binding RestoreArchivedCommand}" Style="{StaticResource DangerButtonStyle}" Visibility="{Binding RestoreArchivedVisibility}" />
                                        <Button Content="打开文件夹" Command="{Binding OpenModFolderCommand}" Style="{StaticResource SubtleButtonStyle}" />
                                        <Button Content="复制摘要" Command="{Binding CopyModInfoCommand}" Style="{StaticResource SubtleButtonStyle}" />
                                    </StackPanel>
                                </Expander>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <Border Grid.Row="7" Style="{StaticResource CardStyle}" Padding="16,12" Visibility="{Binding AvailableVisibility}">
                    <Grid>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <ProgressRing IsActive="{Binding IsBusy}" Width="19" Height="19" />
                            <TextBlock Text="{Binding TaskStatus}" Style="{StaticResource BodyTextStyle}" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding FeedbackMessage}" Foreground="{StaticResource SuccessBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                        <Button Content="打开备份目录" Command="{Binding OpenBackupsCommand}" Style="{StaticResource SubtleButtonStyle}" HorizontalAlignment="Right" />
                    </Grid>
                </Border>
    </Grid>
</Page>
