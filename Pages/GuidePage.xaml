<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="LSMA.Pages.GuidePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer
        HorizontalScrollBarVisibility="Disabled"
        HorizontalContentAlignment="Stretch">
        <StackPanel Padding="30,22,30,30" Spacing="18" HorizontalAlignment="Stretch">
            <Grid ColumnSpacing="18" MinHeight="40">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding SaveContext}" Style="{StaticResource BodyTextStyle}" VerticalAlignment="Center" />
                <AutoSuggestBox x:Name="SearchBox" Grid.Column="1" PlaceholderText="搜索物品、鱼类、人物和节日" QuerySubmitted="Search_QuerySubmitted" Style="{StaticResource TopBarAutoSuggestBoxStyle}" />
            </Grid>

            <Border Style="{StaticResource CardStyle}" Visibility="{Binding EmptyVisibility}">
                <StackPanel Spacing="10">
                    <TextBlock Text="今日建议" Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="选择或创建存档后，LSMA 会根据进度生成启动前建议。" Style="{StaticResource BodyTextStyle}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Visibility="{Binding SuggestionVisibility}">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="今日建议" Style="{StaticResource SectionTitleStyle}" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Tag="suggestions" Click="SectionToggle_Click" Style="{StaticResource NeutralButtonStyle}" Padding="8">
                            <FontIcon Glyph="{Binding SuggestionsToggleGlyph}" FontSize="14" />
                        </Button>
                    </Grid>
                    <StackPanel Grid.Row="1" Visibility="{Binding SuggestionsContentVisibility}" Spacing="12">
                        <ItemsRepeater ItemsSource="{Binding Suggestions}" HorizontalAlignment="Stretch">
                            <ItemsRepeater.Layout>
                                <UniformGridLayout MinItemWidth="320" MinColumnSpacing="12" MinRowSpacing="12" ItemsStretch="Fill" ItemsJustification="Start" />
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="1" CornerRadius="10" MinHeight="150" Padding="16">
                                <Grid ColumnSpacing="12" RowSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="42" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Button
                                        Width="38"
                                        Height="38"
                                        Padding="0"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        Tag="{Binding EffectiveSearchQuery}"
                                        ToolTipService.ToolTip="{Binding EffectiveSearchQuery}"
                                        Click="SearchAction_Click"
                                        VerticalAlignment="Top">
                                        <Grid Width="38" Height="38">
                                            <Border Visibility="{Binding GlyphVisibility}" CornerRadius="8" Background="{ThemeResource AccentSoftBrush}">
                                                <FontIcon Glyph="{Binding IconGlyph}" FontSize="20" Foreground="{StaticResource AccentBrush}" />
                                            </Border>
                                            <Image Source="{Binding IconUri}" Visibility="{Binding ImageVisibility}" Width="34" Height="34" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Grid>
                                    </Button>
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Text="{Binding Category}" Foreground="{StaticResource AccentBrush}" FontSize="12" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="16" TextWrapping="Wrap" MaxLines="2" />
                                    </StackPanel>
                                    <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding Description}" Style="{StaticResource BodyTextStyle}" MaxLines="2" />
                                </Grid>
                            </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                        <Border BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="1" CornerRadius="10" Padding="14">
                            <StackPanel Spacing="6">
                                <TextBlock Text="目标规划" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="{Binding GoalSuggestion}" Style="{StaticResource BodyTextStyle}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource CardStyle}" Visibility="{Binding SearchVisibility}">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding SearchSummary}" Style="{StaticResource SectionTitleStyle}" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Tag="search" Click="SectionToggle_Click" Style="{StaticResource NeutralButtonStyle}" Padding="8">
                            <FontIcon Glyph="{Binding SearchToggleGlyph}" FontSize="14" />
                        </Button>
                    </Grid>
                    <ItemsRepeater Grid.Row="1" ItemsSource="{Binding SearchResults}" Visibility="{Binding SearchContentVisibility}" HorizontalAlignment="Stretch">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Vertical" Spacing="12" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="1" CornerRadius="10" Padding="16">
                                <StackPanel Spacing="14">
                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Button
                                            Width="64"
                                            Height="64"
                                            Padding="0"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            Tag="{Binding SearchQuery}"
                                            ToolTipService.ToolTip="{Binding SearchQuery}"
                                            Click="SearchAction_Click"
                                            VerticalAlignment="Top">
                                            <Grid Width="64" Height="64">
                                                <Border Visibility="{Binding GlyphVisibility}" CornerRadius="12" Background="{ThemeResource AccentSoftBrush}">
                                                    <FontIcon Glyph="{Binding IconGlyph}" FontSize="28" Foreground="{StaticResource AccentBrush}" />
                                                </Border>
                                                <Image Source="{Binding IconUri}" Visibility="{Binding ImageVisibility}" Width="58" Height="58" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Grid>
                                        </Button>
                                        <StackPanel Grid.Column="1" Spacing="5">
                                            <TextBlock Text="{Binding Category}" Foreground="{StaticResource AccentBrush}" FontSize="12" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="20" TextWrapping="Wrap" MaxLines="2" />
                                            <TextBlock Text="{Binding Detail}" Visibility="{Binding DetailVisibility}" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" MaxLines="3" />
                                        </StackPanel>
                                    </Grid>
                                    <ItemsRepeater ItemsSource="{Binding Sections}" Visibility="{Binding SectionsVisibility}">
                                        <ItemsRepeater.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Spacing="8" Margin="0,2,0,8">
                                                    <TextBlock Text="{Binding Title}" Foreground="{StaticResource AccentBrush}" FontSize="13" FontWeight="SemiBold" />
                                                    <ItemsRepeater ItemsSource="{Binding Lines}" Visibility="{Binding LinesVisibility}">
                                                        <ItemsRepeater.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding}" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" MaxLines="2" />
                                                            </DataTemplate>
                                                        </ItemsRepeater.ItemTemplate>
                                                    </ItemsRepeater>
                                                    <ItemsRepeater ItemsSource="{Binding Actions}" Visibility="{Binding ActionsVisibility}">
                                                        <ItemsRepeater.Layout>
                                                            <UniformGridLayout MinItemWidth="190" MinColumnSpacing="8" MinRowSpacing="8" ItemsStretch="Fill" ItemsJustification="Start" />
                                                        </ItemsRepeater.Layout>
                                                        <ItemsRepeater.ItemTemplate>
                                                            <DataTemplate>
                                                                <Button
                                                                    Tag="{Binding Query}"
                                                                    Click="SearchAction_Click"
                                                                    Style="{StaticResource NeutralButtonStyle}"
                                                                    HorizontalAlignment="Stretch"
                                                                    HorizontalContentAlignment="Stretch"
                                                                    Padding="9,7">
                                                                    <Grid ColumnSpacing="8">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="30" />
                                                                            <ColumnDefinition Width="*" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <Grid Width="28" Height="28" VerticalAlignment="Center">
                                                                            <Border Visibility="{Binding GlyphVisibility}" CornerRadius="6" Background="{ThemeResource AccentSoftBrush}">
                                                                                <FontIcon Glyph="{Binding IconGlyph}" FontSize="14" Foreground="{StaticResource AccentBrush}" />
                                                                            </Border>
                                                                            <Image Source="{Binding IconUri}" Visibility="{Binding ImageVisibility}" Width="26" Height="26" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                        </Grid>
                                                                        <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                                                                            <TextBlock Text="{Binding Label}" FontWeight="SemiBold" TextWrapping="Wrap" MaxLines="1" />
                                                                            <TextBlock Text="{Binding Detail}" Visibility="{Binding DetailVisibility}" Style="{StaticResource MutedTextStyle}" FontSize="12" TextWrapping="Wrap" MaxLines="1" />
                                                                        </StackPanel>
                                                                    </Grid>
                                                                </Button>
                                                            </DataTemplate>
                                                        </ItemsRepeater.ItemTemplate>
                                                    </ItemsRepeater>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>
                                </StackPanel>
                            </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </Grid>
            </Border>

            <StackPanel Visibility="{Binding StructuredVisibility}" Spacing="18">
                <Border Style="{StaticResource CardStyle}">
                    <Grid RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="作物收益" Style="{StaticResource SectionTitleStyle}" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Tag="crops" Click="SectionToggle_Click" Style="{StaticResource NeutralButtonStyle}" Padding="8">
                                <FontIcon Glyph="{Binding CropsToggleGlyph}" FontSize="14" />
                            </Button>
                        </Grid>
                    <ItemsRepeater Grid.Row="1" ItemsSource="{Binding Crops}" Visibility="{Binding CropsContentVisibility}" HorizontalAlignment="Stretch">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MinItemWidth="320" MinColumnSpacing="12" MinRowSpacing="12" ItemsStretch="Fill" ItemsJustification="Start" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="1" CornerRadius="10" MinHeight="208" Padding="14">
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="42" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button
                                            Width="38"
                                            Height="38"
                                            Padding="0"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            Tag="{Binding SearchQuery}"
                                            ToolTipService.ToolTip="{Binding SearchQuery}"
                                            Click="SearchAction_Click"
                                            VerticalAlignment="Top">
                                            <Image Source="{Binding IconUri}" Width="34" Height="34" Stretch="Uniform" />
                                        </Button>
                                        <StackPanel Grid.Column="1" Spacing="4">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextWrapping="Wrap" MaxLines="1" />
                                            <TextBlock Text="{Binding GrowthText}" Style="{StaticResource MutedTextStyle}" MaxLines="1" />
                                            <TextBlock Text="{Binding HarvestText}" Style="{StaticResource MutedTextStyle}" MaxLines="1" />
                                            <TextBlock Text="{Binding ProfitText}" Style="{StaticResource MutedTextStyle}" MaxLines="1" />
                                            <TextBlock Text="{Binding RawPriceText}" Style="{StaticResource BodyTextStyle}" MaxLines="1" />
                                            <TextBlock Text="{Binding ArtisanPriceText}" Foreground="{StaticResource AccentBrush}" TextWrapping="Wrap" MaxLines="2" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <Grid RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding FishHeading}" Style="{StaticResource SectionTitleStyle}" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Tag="fish" Click="SectionToggle_Click" Style="{StaticResource NeutralButtonStyle}" Padding="8">
                                <FontIcon Glyph="{Binding FishToggleGlyph}" FontSize="14" />
                            </Button>
                        </Grid>
                    <ItemsRepeater Grid.Row="1" ItemsSource="{Binding Fish}" Visibility="{Binding FishContentVisibility}" HorizontalAlignment="Stretch">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MinItemWidth="320" MinColumnSpacing="12" MinRowSpacing="12" ItemsStretch="Fill" ItemsJustification="Start" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="1" CornerRadius="10" MinHeight="186" Padding="14">
                                    <Grid RowSpacing="8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="38" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Button
                                                Width="36"
                                                Height="36"
                                                Padding="0"
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                Tag="{Binding SearchQuery}"
                                                ToolTipService.ToolTip="{Binding SearchQuery}"
                                                Click="SearchAction_Click"
                                                VerticalAlignment="Top">
                                                <Image Source="{Binding IconUri}" Width="32" Height="32" Stretch="Uniform" />
                                            </Button>
                                            <StackPanel Grid.Column="1" Spacing="2">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextWrapping="Wrap" MaxLines="1" />
                                                <TextBlock Text="{Binding SeasonWeatherText}" Style="{StaticResource MutedTextStyle}" MaxLines="1" />
                                            </StackPanel>
                                            <Border Grid.Column="2" Visibility="{Binding BadgeVisibility}" Background="{ThemeResource AccentSoftBrush}" CornerRadius="8" Padding="8,3" VerticalAlignment="Top">
                                                <TextBlock Text="{Binding BadgeText}" Foreground="{StaticResource AccentBrush}" FontSize="12" FontWeight="SemiBold" />
                                            </Border>
                                        </Grid>
                                        <TextBlock Grid.Row="1" Text="{Binding CategoryText}" Style="{StaticResource BodyTextStyle}" MaxLines="1" />
                                        <TextBlock Grid.Row="2" Text="{Binding PriceText}" Style="{StaticResource MutedTextStyle}" MaxLines="1" />
                                        <TextBlock Grid.Row="3" Text="{Binding SmokedPriceText}" Foreground="{StaticResource AccentBrush}" TextWrapping="Wrap" MaxLines="2" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <Grid RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="最近节日" Style="{StaticResource SectionTitleStyle}" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Tag="festivals" Click="SectionToggle_Click" Style="{StaticResource NeutralButtonStyle}" Padding="8">
                                <FontIcon Glyph="{Binding FestivalsToggleGlyph}" FontSize="14" />
                            </Button>
                        </Grid>
                    <ItemsRepeater Grid.Row="1" ItemsSource="{Binding Festivals}" Visibility="{Binding FestivalsContentVisibility}" HorizontalAlignment="Stretch">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MinItemWidth="320" MinColumnSpacing="12" MinRowSpacing="12" ItemsStretch="Fill" ItemsJustification="Start" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="1" CornerRadius="10" MinHeight="154" Padding="14">
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="42" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button
                                            Width="38"
                                            Height="38"
                                            Padding="0"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            Tag="{Binding SearchQuery}"
                                            ToolTipService.ToolTip="{Binding SearchQuery}"
                                            Click="SearchAction_Click"
                                            VerticalAlignment="Top">
                                            <Image Source="{Binding IconUri}" Width="34" Height="34" Stretch="Uniform" />
                                        </Button>
                                        <StackPanel Grid.Column="1" Spacing="3">
                                            <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource AccentBrush}" FontSize="12" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding CountdownText}" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextWrapping="Wrap" MaxLines="1" />
                                            <TextBlock Text="{Binding DateText}" Style="{StaticResource MutedTextStyle}" MaxLines="1" />
                                            <TextBlock Text="{Binding Detail}" Visibility="{Binding DetailVisibility}" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" MaxLines="2" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardStyle}" Visibility="{Binding BundleVisibility}">
                    <Grid RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="社区中心" Style="{StaticResource SectionTitleStyle}" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Tag="bundles" Click="SectionToggle_Click" Style="{StaticResource NeutralButtonStyle}" Padding="8">
                                <FontIcon Glyph="{Binding BundlesToggleGlyph}" FontSize="14" />
                            </Button>
                        </Grid>
                    <ItemsRepeater Grid.Row="1" ItemsSource="{Binding Bundles}" Visibility="{Binding BundlesContentVisibility}" HorizontalAlignment="Stretch">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MinItemWidth="320" MinColumnSpacing="12" MinRowSpacing="12" ItemsStretch="Fill" ItemsJustification="Start" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="1" CornerRadius="10" MinHeight="216" Padding="14">
                                    <Grid ColumnSpacing="10" RowSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="42" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Button
                                            Width="38"
                                            Height="38"
                                            Padding="0"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            Tag="{Binding SearchQuery}"
                                            ToolTipService.ToolTip="{Binding SearchQuery}"
                                            Click="SearchAction_Click"
                                            VerticalAlignment="Top">
                                            <Image Source="{Binding IconUri}" Width="34" Height="34" Stretch="Uniform" />
                                        </Button>
                                        <StackPanel Grid.Column="1" Spacing="4">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextWrapping="Wrap" MaxLines="1" />
                                            <TextBlock Text="{Binding Detail}" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" MaxLines="2" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding ProgressText}" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" VerticalAlignment="Top" Margin="8,0,0,0" />
                                        <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Spacing="10" Visibility="{Binding ItemsVisibility}">
                                            <Border BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="1" CornerRadius="9" Padding="10" Visibility="{Binding PendingItemsVisibility}">
                                                <StackPanel Spacing="8">
                                                    <TextBlock Text="未完成" Foreground="{StaticResource AccentBrush}" FontSize="13" FontWeight="SemiBold" />
                                                    <ItemsRepeater ItemsSource="{Binding PendingItems}" HorizontalAlignment="Stretch">
                                                        <ItemsRepeater.Layout>
                                                            <UniformGridLayout MinItemWidth="154" MinColumnSpacing="8" MinRowSpacing="8" ItemsStretch="Fill" ItemsJustification="Start" />
                                                        </ItemsRepeater.Layout>
                                                        <ItemsRepeater.ItemTemplate>
                                                            <DataTemplate>
                                                                <Button
                                                                    Tag="{Binding SearchQuery}"
                                                                    ToolTipService.ToolTip="{Binding SearchQuery}"
                                                                    Click="SearchAction_Click"
                                                                    Style="{StaticResource NeutralButtonStyle}"
                                                                    HorizontalAlignment="Stretch"
                                                                    HorizontalContentAlignment="Stretch"
                                                                    Padding="9,8">
                                                                    <Grid ColumnSpacing="8">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="30" />
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="Auto" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <Image Source="{Binding IconUri}" Width="28" Height="28" Stretch="Uniform" VerticalAlignment="Center" />
                                                                        <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                                                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextWrapping="Wrap" MaxLines="1" />
                                                                            <TextBlock Text="{Binding Detail}" Style="{StaticResource MutedTextStyle}" FontSize="12" TextWrapping="Wrap" MaxLines="1" />
                                                                        </StackPanel>
                                                                        <Border Grid.Column="2" Background="{ThemeResource AccentSoftBrush}" CornerRadius="7" Padding="6,2" VerticalAlignment="Top">
                                                                            <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="SemiBold" />
                                                                        </Border>
                                                                    </Grid>
                                                                </Button>
                                                            </DataTemplate>
                                                        </ItemsRepeater.ItemTemplate>
                                                    </ItemsRepeater>
                                                </StackPanel>
                                            </Border>
                                            <Border BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="1" CornerRadius="9" Padding="10" Visibility="{Binding CompletedItemsVisibility}">
                                                <StackPanel Spacing="8">
                                                    <TextBlock Text="已完成" Foreground="{StaticResource SuccessBrush}" FontSize="13" FontWeight="SemiBold" />
                                                    <ItemsRepeater ItemsSource="{Binding CompletedItems}" HorizontalAlignment="Stretch">
                                                        <ItemsRepeater.Layout>
                                                            <UniformGridLayout MinItemWidth="154" MinColumnSpacing="8" MinRowSpacing="8" ItemsStretch="Fill" ItemsJustification="Start" />
                                                        </ItemsRepeater.Layout>
                                                        <ItemsRepeater.ItemTemplate>
                                                            <DataTemplate>
                                                                <Button
                                                                    Tag="{Binding SearchQuery}"
                                                                    ToolTipService.ToolTip="{Binding SearchQuery}"
                                                                    Click="SearchAction_Click"
                                                                    Style="{StaticResource NeutralButtonStyle}"
                                                                    HorizontalAlignment="Stretch"
                                                                    HorizontalContentAlignment="Stretch"
                                                                    Padding="9,8">
                                                                    <Grid ColumnSpacing="8">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="30" />
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="Auto" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <Image Source="{Binding IconUri}" Width="28" Height="28" Stretch="Uniform" VerticalAlignment="Center" />
                                                                        <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                                                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextWrapping="Wrap" MaxLines="1" />
                                                                            <TextBlock Text="{Binding Detail}" Style="{StaticResource MutedTextStyle}" FontSize="12" TextWrapping="Wrap" MaxLines="1" />
                                                                        </StackPanel>
                                                                        <Grid Grid.Column="2" VerticalAlignment="Top">
                                                                            <Border Visibility="{Binding DonatedStatusVisibility}" Background="{StaticResource SuccessBrush}" CornerRadius="7" Padding="6,2">
                                                                                <TextBlock Text="{Binding StatusText}" Foreground="White" FontSize="11" FontWeight="SemiBold" />
                                                                            </Border>
                                                                            <Border Visibility="{Binding SatisfiedStatusVisibility}" Background="{ThemeResource CardBorderBrush}" CornerRadius="7" Padding="6,2">
                                                                                <TextBlock Text="{Binding StatusText}" Foreground="{ThemeResource MutedTextBrush}" FontSize="11" FontWeight="SemiBold" />
                                                                            </Border>
                                                                        </Grid>
                                                                    </Grid>
                                                                </Button>
                                                            </DataTemplate>
                                                        </ItemsRepeater.ItemTemplate>
                                                    </ItemsRepeater>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                    </Grid>
                </Border>

                <TextBlock Text="资料与图标由本机游戏内容生成，鱼类按当前季节与天气筛选。" Style="{StaticResource MutedTextStyle}" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
