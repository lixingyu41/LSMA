<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="LSMA.Pages.GuidePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" HorizontalContentAlignment="Stretch">
        <StackPanel Padding="30,22,30,30" Spacing="18" HorizontalAlignment="Stretch">
            <Grid ColumnSpacing="18">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="320" /></Grid.ColumnDefinitions>
                <TextBlock Text="{Binding SaveContext}" Style="{StaticResource BodyTextStyle}" VerticalAlignment="Center" />
                <AutoSuggestBox Grid.Column="1" PlaceholderText="搜索建议与攻略模块" QuerySubmitted="Search_QuerySubmitted" VerticalAlignment="Center" />
            </Grid>

            <Border Style="{StaticResource CardStyle}" Visibility="{Binding EmptyVisibility}">
                <StackPanel Spacing="10">
                    <TextBlock Text="今日建议" Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="选择或创建存档后，LSMA 会根据进度生成启动前建议。" Style="{StaticResource BodyTextStyle}" />
                </StackPanel>
            </Border>

            <StackPanel Visibility="{Binding SuggestionVisibility}" Spacing="12">
                <TextBlock Text="今日建议" Style="{StaticResource SectionTitleStyle}" />
                <ItemsControl ItemsSource="{Binding Suggestions}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><StackPanel Spacing="10" /></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CardStyle}" Padding="17">
                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="75" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Category}" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="16" />
                                        <TextBlock Text="{Binding Description}" Style="{StaticResource BodyTextStyle}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="目标规划" Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="{Binding GoalSuggestion}" Style="{StaticResource BodyTextStyle}" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <TextBlock Text="结构化查询" Style="{StaticResource SectionTitleStyle}" Margin="0,8,0,0" />
            <Grid ColumnSpacing="12" RowSpacing="12">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="9">
                        <TextBlock Text="送礼与生日" Style="{StaticResource SectionTitleStyle}" />
                        <ItemsControl ItemsSource="{Binding Birthdays}">
                            <ItemsControl.ItemTemplate><DataTemplate>
                                <Grid Margin="0,4"><TextBlock Text="{Binding Npc}" /><TextBlock Text="{Binding DateText}" HorizontalAlignment="Center" Foreground="{StaticResource AccentBrush}" /><TextBlock Text="{Binding LovedGiftHint}" HorizontalAlignment="Right" Style="{StaticResource MutedTextStyle}" /></Grid>
                            </DataTemplate></ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="9">
                        <TextBlock Text="钓鱼" Style="{StaticResource SectionTitleStyle}" />
                        <ItemsControl ItemsSource="{Binding Fish}">
                            <ItemsControl.ItemTemplate><DataTemplate>
                                <StackPanel Margin="0,4"><TextBlock Text="{Binding Name}" /><TextBlock Text="{Binding Detail}" Style="{StaticResource MutedTextStyle}" /></StackPanel>
                            </DataTemplate></ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="9">
                        <TextBlock Text="作物收益" Style="{StaticResource SectionTitleStyle}" />
                        <ItemsControl ItemsSource="{Binding Crops}">
                            <ItemsControl.ItemTemplate><DataTemplate>
                                <StackPanel Margin="0,4"><TextBlock Text="{Binding Name}" /><TextBlock Text="{Binding Detail}" Style="{StaticResource MutedTextStyle}" /></StackPanel>
                            </DataTemplate></ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="9">
                        <TextBlock Text="社区中心" Style="{StaticResource SectionTitleStyle}" />
                        <ItemsControl ItemsSource="{Binding Bundles}">
                            <ItemsControl.ItemTemplate><DataTemplate>
                                <StackPanel Margin="0,4"><TextBlock Text="{Binding Name}" /><TextBlock Text="{Binding Detail}" Style="{StaticResource MutedTextStyle}" /></StackPanel>
                            </DataTemplate></ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                <Border Grid.Row="2" Grid.ColumnSpan="2" Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="9">
                        <TextBlock Text="食谱 / 制作" Style="{StaticResource SectionTitleStyle}" />
                        <ItemsControl ItemsSource="{Binding Recipes}">
                            <ItemsControl.ItemTemplate><DataTemplate>
                                <StackPanel Margin="0,4"><TextBlock Text="{Binding Name}" /><TextBlock Text="{Binding Detail}" Style="{StaticResource MutedTextStyle}" /></StackPanel>
                            </DataTemplate></ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="基础结构化资料来源：Stardew Valley Wiki（CC BY-NC-SA 3.0），目标游戏版本 1.6；不包含游戏图片或原文复制。" Style="{StaticResource MutedTextStyle}" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
