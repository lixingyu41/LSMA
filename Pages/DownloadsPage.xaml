<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Name="DownloadsPageRoot"
    x:Class="LSMA.Pages.DownloadsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:LSMA.Pages">

    <Grid Padding="30,16,30,24" RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBox Text="{Binding OnlineQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="搜索模组或 Nexus ID" Width="260" Height="36" KeyDown="OnlineSearchBox_KeyDown" />
                <ComboBox ItemsSource="{Binding OnlineCategories}" SelectedItem="{Binding SelectedOnlineCategory, Mode=TwoWay}" DisplayMemberPath="Name" MinWidth="160" Height="36" PlaceholderText="分类" />
                <Button Content="刷新" Command="{Binding RefreshCommand}" Style="{StaticResource SubtleButtonStyle}" MinHeight="36" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="380" />
            </Grid.ColumnDefinitions>

            <!-- Mod list -->
            <Border Style="{StaticResource CardStyle}" Padding="8">
                <ListView x:Name="OnlineModsList"
                          ItemsSource="{Binding OnlineMods}"
                          SelectedItem="{Binding SelectedOnlineMod, Mode=TwoWay}"
                          Loaded="OnlineModsList_Loaded"
                          SelectionMode="Single"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.VerticalScrollMode="Enabled">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="VerticalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="MinHeight" Value="0" />
                            <Setter Property="UseSystemFocusVisuals" Value="False" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <ContentPresenter Content="{TemplateBinding Content}"
                                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,4,8,4"
                                  PointerEntered="OnlineModListItem_PointerEntered"
                                  PointerExited="OnlineModListItem_PointerExited">
                                <Border Background="{ThemeResource CardBackgroundBrush}"
                                        BorderBrush="{ThemeResource CardBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8" />
                                <Border Background="{ThemeResource AccentSoftBrush}"
                                        CornerRadius="8"
                                        Opacity="{Binding HoverLayerOpacity}" />
                                <Border Background="{ThemeResource AccentSoftBrush}"
                                        CornerRadius="8"
                                        Opacity="{Binding SelectedLayerOpacity}" />
                                <Grid Padding="10,8" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid Margin="0,4,0,4">
                                        <Border Background="{StaticResource AccentBrush}"
                                                CornerRadius="1.5"
                                                Opacity="{Binding HoverIndicatorOpacity}" />
                                        <Border Background="{StaticResource AccentBrush}"
                                                CornerRadius="1.5"
                                                Opacity="{Binding SelectedIndicatorOpacity}" />
                                    </Grid>
                                    <Grid Grid.Column="1" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                        <StackPanel Spacing="3">
                                            <TextBlock Text="{Binding DisplayName}" Foreground="{Binding ListTextBrush}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Author}" Foreground="{Binding ListTextBrush}" FontSize="14" Opacity="0.72" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding ResultStateText}" Foreground="{StaticResource AccentBrush}" FontSize="14" Visibility="{Binding ResultStateVisibility}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Summary}" Foreground="{Binding ListTextBrush}" FontSize="14" Opacity="0.72" TextTrimming="CharacterEllipsis" MinHeight="18" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding ModIdText}" Foreground="{Binding ListTextBrush}" FontSize="14" Opacity="0.72" HorizontalAlignment="Right" />
                                            <TextBlock Text="{Binding Version}" Foreground="{Binding ListTextBrush}" FontSize="14" Opacity="0.72" HorizontalAlignment="Right" />
                                            <TextBlock Text="{Binding DownloadStatusText}" Foreground="{Binding ListTextBrush}" HorizontalAlignment="Right" />
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>

            <!-- Detail panel -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                <ScrollViewer>
                    <StackPanel Spacing="12">
                        <TextBlock Text="{Binding SelectedOnlineMod.DisplayName}" Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="{Binding SelectedOnlineMod.Summary}" Style="{StaticResource BodyTextStyle}" />

                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <ToggleButton Content="{Binding FavoriteButtonText}" Command="{Binding ToggleFavoriteCommand}"
                                          IsChecked="{Binding SelectedOnlineMod.IsFavorite, Mode=OneWay}"
                                          Style="{StaticResource ChoiceToggleStyle}" />
                            <Button Content="打开 Nexus" Command="{Binding OpenNexusCommand}" CommandParameter="{Binding SelectedOnlineMod}"
                                    Style="{StaticResource SubtleButtonStyle}" />
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox ItemsSource="{Binding OnlineFiles}" SelectedItem="{Binding SelectedOnlineFile, Mode=TwoWay}"
                                      DisplayMemberPath="DisplayText" PlaceholderText="历史版本" MinHeight="32" />
                            <Button Grid.Column="1" Content="刷新所有历史版本" Command="{Binding LoadFilesCommand}"
                                    Style="{StaticResource SubtleButtonStyle}" MinHeight="32" Padding="12,0" />
                        </Grid>

                        <Button Content="下载最新" Command="{Binding DownloadFileCommand}" Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Stretch" />
                        <Button Content="取消下载" Command="{Binding CancelDownloadCommand}" Style="{StaticResource NeutralButtonStyle}" HorizontalAlignment="Left" />
                        <TextBlock Text="{Binding FeedbackMessage}" Foreground="{StaticResource SuccessBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>
