<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="PageTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="30" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource PrimaryTextBrush}" />
    </Style>
    <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource PrimaryTextBrush}" />
    </Style>
    <Style x:Key="BodyTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{ThemeResource SecondaryTextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style x:Key="MutedTextStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyTextStyle}">
        <Setter Property="Foreground" Value="{ThemeResource MutedTextBrush}" />
    </Style>
    <Style x:Key="PaletteDescriptionTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Opacity" Value="0.82" />
    </Style>
    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource CardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="20" />
    </Style>
    <ControlTemplate x:Key="ActionButtonTemplate" TargetType="Button">
        <Grid x:Name="ButtonRoot" RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
                <ScaleTransform x:Name="ButtonScale" ScaleX="1" ScaleY="1" />
            </Grid.RenderTransform>
            <Border
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{TemplateBinding CornerRadius}" />
            <Border
                x:Name="ButtonHoverLayer"
                Background="#FFFFFFFF"
                CornerRadius="{TemplateBinding CornerRadius}"
                IsHitTestVisible="False"
                Opacity="0" />
            <ContentPresenter
                x:Name="ButtonContent"
                Content="{TemplateBinding Content}"
                ContentTemplate="{TemplateBinding ContentTemplate}"
                Foreground="{TemplateBinding Foreground}"
                FontSize="{TemplateBinding FontSize}"
                FontWeight="{TemplateBinding FontWeight}"
                Opacity="0.9"
                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                Padding="{TemplateBinding Padding}" />
            <VisualStateManager.VisualStateGroups>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualStateGroup.Transitions>
                        <VisualTransition To="PointerOver" GeneratedDuration="0:0:0.14" />
                        <VisualTransition From="PointerOver" GeneratedDuration="0:0:0.14" />
                        <VisualTransition To="Pressed" GeneratedDuration="0:0:0.08" />
                        <VisualTransition From="Pressed" GeneratedDuration="0:0:0.12" />
                    </VisualStateGroup.Transitions>
                    <VisualState x:Name="Normal">
                        <VisualState.Setters>
                            <Setter Target="ButtonHoverLayer.Opacity" Value="0" />
                            <Setter Target="ButtonScale.ScaleX" Value="1" />
                            <Setter Target="ButtonScale.ScaleY" Value="1" />
                            <Setter Target="ButtonContent.Opacity" Value="0.9" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="PointerOver">
                        <VisualState.Setters>
                            <Setter Target="ButtonHoverLayer.Opacity" Value="0.14" />
                            <Setter Target="ButtonScale.ScaleX" Value="1.012" />
                            <Setter Target="ButtonScale.ScaleY" Value="1.012" />
                            <Setter Target="ButtonContent.Opacity" Value="1" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Pressed">
                        <VisualState.Setters>
                            <Setter Target="ButtonHoverLayer.Opacity" Value="0.08" />
                            <Setter Target="ButtonScale.ScaleX" Value="0.985" />
                            <Setter Target="ButtonScale.ScaleY" Value="0.985" />
                            <Setter Target="ButtonContent.Opacity" Value="1" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Target="ButtonRoot.Opacity" Value="0.45" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>
        </Grid>
    </ControlTemplate>
    <Style x:Key="ActionButtonBaseStyle" TargetType="Button">
        <Setter Property="Template" Value="{StaticResource ActionButtonTemplate}" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="14,9" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonBaseStyle}">
        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        <Setter Property="Foreground" Value="#252019" />
        <Setter Property="Padding" Value="18,10" />
    </Style>
    <Style x:Key="SubtleButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonBaseStyle}">
        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        <Setter Property="Foreground" Value="#252019" />
    </Style>
    <Style x:Key="NeutralButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonBaseStyle}">
        <Setter Property="Background" Value="{ThemeResource CardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardBorderBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource SecondaryTextBrush}" />
    </Style>
    <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource NeutralButtonStyle}">
        <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
        <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
    </Style>
    <Style x:Key="ChoiceButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonBaseStyle}">
        <Setter Property="Background" Value="{ThemeResource CardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardBorderBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource SecondaryTextBrush}" />
        <Setter Property="Padding" Value="16,9" />
        <Setter Property="MinWidth" Value="86" />
    </Style>
    <Style x:Key="SelectedChoiceButtonStyle" TargetType="Button" BasedOn="{StaticResource ChoiceButtonStyle}">
        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        <Setter Property="Foreground" Value="#252019" />
    </Style>
    <Style x:Key="FilterPillButtonStyle" TargetType="Button">
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="Padding" Value="4,10" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{ThemeResource SecondaryTextBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="FontSize" Value="17" />
        <Setter Property="FontWeight" Value="Normal" />
    </Style>
    <Style x:Key="ChoiceToggleStyle" TargetType="ToggleButton">
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16,9" />
        <Setter Property="MinWidth" Value="86" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Grid x:Name="ChoiceRoot" RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <ScaleTransform x:Name="ChoiceScale" ScaleX="1" ScaleY="1" />
                        </Grid.RenderTransform>
                        <Border
                            x:Name="ChoiceSurface"
                            Background="{ThemeResource CardBackgroundBrush}"
                            BorderBrush="{ThemeResource CardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{TemplateBinding CornerRadius}" />
                        <Border
                            x:Name="ChoiceHoverLayer"
                            Background="#FFFFFFFF"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            IsHitTestVisible="False"
                            Opacity="0" />
                        <ContentPresenter
                            x:Name="ChoiceContent"
                            Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            Foreground="{ThemeResource SecondaryTextBrush}"
                            FontSize="{TemplateBinding FontSize}"
                            FontWeight="{TemplateBinding FontWeight}"
                            Opacity="0.9"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            Padding="{TemplateBinding Padding}" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualStateGroup.Transitions>
                                    <VisualTransition To="PointerOver" GeneratedDuration="0:0:0.14" />
                                    <VisualTransition From="PointerOver" GeneratedDuration="0:0:0.14" />
                                    <VisualTransition To="Pressed" GeneratedDuration="0:0:0.08" />
                                    <VisualTransition From="Pressed" GeneratedDuration="0:0:0.12" />
                                </VisualStateGroup.Transitions>
                                <VisualState x:Name="Normal">
                                    <VisualState.Setters>
                                        <Setter Target="ChoiceHoverLayer.Opacity" Value="0" />
                                        <Setter Target="ChoiceScale.ScaleX" Value="1" />
                                        <Setter Target="ChoiceScale.ScaleY" Value="1" />
                                        <Setter Target="ChoiceContent.Opacity" Value="0.9" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="ChoiceHoverLayer.Opacity" Value="0.12" />
                                        <Setter Target="ChoiceScale.ScaleX" Value="1.012" />
                                        <Setter Target="ChoiceScale.ScaleY" Value="1.012" />
                                        <Setter Target="ChoiceContent.Opacity" Value="1" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="ChoiceHoverLayer.Opacity" Value="0.07" />
                                        <Setter Target="ChoiceScale.ScaleX" Value="0.985" />
                                        <Setter Target="ChoiceScale.ScaleY" Value="0.985" />
                                        <Setter Target="ChoiceContent.Opacity" Value="1" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Target="ChoiceRoot.Opacity" Value="0.45" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                            <VisualStateGroup x:Name="CheckStates">
                                <VisualState x:Name="Unchecked">
                                    <VisualState.Setters>
                                        <Setter Target="ChoiceSurface.Background" Value="{ThemeResource CardBackgroundBrush}" />
                                        <Setter Target="ChoiceSurface.BorderBrush" Value="{ThemeResource CardBorderBrush}" />
                                        <Setter Target="ChoiceContent.Foreground" Value="{ThemeResource SecondaryTextBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Checked">
                                    <VisualState.Setters>
                                        <Setter Target="ChoiceSurface.Background" Value="{StaticResource AccentBrush}" />
                                        <Setter Target="ChoiceSurface.BorderBrush" Value="{StaticResource AccentBrush}" />
                                        <Setter Target="ChoiceContent.Foreground" Value="#252019" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Indeterminate">
                                    <VisualState.Setters>
                                        <Setter Target="ChoiceSurface.Background" Value="{ThemeResource CardBackgroundBrush}" />
                                        <Setter Target="ChoiceSurface.BorderBrush" Value="{ThemeResource CardBorderBrush}" />
                                        <Setter Target="ChoiceContent.Foreground" Value="{ThemeResource SecondaryTextBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="ChoiceRadioStyle" TargetType="RadioButton">
