                                </VisualState>
                            </VisualStateGroup>
                            <VisualStateGroup x:Name="CheckStates">
                                <VisualState x:Name="Unchecked">
                                    <VisualState.Setters>
                                        <Setter Target="ChoiceSurface.Background" Value="{ThemeResource CardBackgroundBrush}" />
                                        <Setter Target="ChoiceSurface.BorderBrush" Value="{ThemeResource CardBorderBrush}" />
                                        <Setter Target="ChoiceContent.Foreground" Value="{ThemeResource SecondaryTextBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Checked">
                                    <VisualState.Setters>
                                        <Setter Target="ChoiceSurface.Background" Value="{StaticResource AccentBrush}" />
                                        <Setter Target="ChoiceSurface.BorderBrush" Value="{StaticResource AccentBrush}" />
                                        <Setter Target="ChoiceContent.Foreground" Value="#252019" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="PaletteRadioStyle" TargetType="RadioButton" BasedOn="{StaticResource ChoiceRadioStyle}">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Padding" Value="13" />
        <Setter Property="Height" Value="100" />
    </Style>
    <Style TargetType="AppBarButton">
        <Setter Property="Foreground" Value="#252019" />
        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="MinWidth" Value="84" />
        <Setter Property="Height" Value="42" />
        <Setter Property="Margin" Value="0,0,10,0" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="AppBarButton">
                    <Grid x:Name="CommandRoot" RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <ScaleTransform x:Name="CommandScale" ScaleX="1" ScaleY="1" />
                        </Grid.RenderTransform>
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8" />
                        <Border
                            x:Name="CommandHoverLayer"
                            Background="#FFFFFFFF"
                            CornerRadius="8"
                            IsHitTestVisible="False"
                            Opacity="0" />
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="12,0">
                            <ContentPresenter Content="{TemplateBinding Icon}" VerticalAlignment="Center" />
                            <TextBlock x:Name="CommandLabel" Text="{TemplateBinding Label}" Foreground="{TemplateBinding Foreground}" FontSize="{TemplateBinding FontSize}" FontWeight="{TemplateBinding FontWeight}" Opacity="0.9" VerticalAlignment="Center" />
                        </StackPanel>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualStateGroup.Transitions>
                                    <VisualTransition To="PointerOver" GeneratedDuration="0:0:0.14" />
                                    <VisualTransition From="PointerOver" GeneratedDuration="0:0:0.14" />
                                    <VisualTransition To="Pressed" GeneratedDuration="0:0:0.08" />
                                    <VisualTransition From="Pressed" GeneratedDuration="0:0:0.12" />
                                </VisualStateGroup.Transitions>
                                <VisualState x:Name="Normal">
                                    <VisualState.Setters>
                                        <Setter Target="CommandHoverLayer.Opacity" Value="0" />
                                        <Setter Target="CommandScale.ScaleX" Value="1" />
                                        <Setter Target="CommandScale.ScaleY" Value="1" />
                                        <Setter Target="CommandLabel.Opacity" Value="0.9" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="CommandHoverLayer.Opacity" Value="0.14" />
                                        <Setter Target="CommandScale.ScaleX" Value="1.012" />
                                        <Setter Target="CommandScale.ScaleY" Value="1.012" />
                                        <Setter Target="CommandLabel.Opacity" Value="1" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="CommandHoverLayer.Opacity" Value="0.08" />
                                        <Setter Target="CommandScale.ScaleX" Value="0.985" />
                                        <Setter Target="CommandScale.ScaleY" Value="0.985" />
                                        <Setter Target="CommandLabel.Opacity" Value="1" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Target="CommandRoot.Opacity" Value="0.45" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
