        <Setter Property="Padding" Value="16,9" />
        <Setter Property="MinWidth" Value="86" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
