<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="LSMA.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:LSMA">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="Themes/Colors.xaml" />
                <ResourceDictionary Source="Themes/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <!-- Kept local so runtime palette changes do not write into a Source dictionary. -->
            <Color x:Key="SystemAccentColor">#F2C94C</Color>
            <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#F2C94C" />
            <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="#F2C94C" Opacity="0.88" />
            <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="#F2C94C" Opacity="0.74" />
            <SolidColorBrush x:Key="AccentFillColorDisabledBrush" Color="#F2C94C" Opacity="0.42" />
            <SolidColorBrush x:Key="TextOnAccentFillColorPrimaryBrush" Color="#252019" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
